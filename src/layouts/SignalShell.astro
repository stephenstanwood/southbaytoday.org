---
import BaseLayout from "./BaseLayout.astro";
import SignalApp from "../components/south-bay/SignalApp.tsx";
import type { Tab } from "../lib/south-bay/types";

interface Props {
  title?: string;
  description?: string;
  initialTab?: Tab;
}

// The app shell server-renders at build time (client:load) on every page,
// homepage included: crawlers and first paint get the masthead/nav/footer
// plus each view's deterministic initial HTML. Views keep their first render
// free of clock/localStorage/random reads (refined in mounted effects) so
// hydration matches the build's HTML.
const {
  title = "The South Bay Today",
  description = "What should we do today? Day plans, events, restaurants, and parks across Campbell, Los Gatos, Mountain View, San Jose, Palo Alto, and 6 more South Bay cities.",
  initialTab,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  themeColor="#F7F8FA"
  fontsUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Permanent+Marker&display=swap"
>
  <Fragment slot="head">
    <style is:global>
      :root {
        --sb-bg: #FAF9F6;
        --sb-card: #FFFFFF;
        --sb-ink: #1A1A1A;
        --sb-muted: #555555;
        --sb-light: #888888;
        --sb-border: #C8C4BC;
        --sb-border-light: #E5E2DB;
        --sb-rule: #1A1A1A;
        --sb-primary: #1A1A1A;
        --sb-primary-light: #F0EFEC;
        --sb-accent: #C0392B;
        --sb-accent-light: #FDEEEC;
        --sb-live: #C0392B;
        --sb-win: #1A1A1A;
        --sb-loss: #999999;
        --sb-radius: 2px;
        --sb-shadow: none;
        --sb-shadow-hover: 0 2px 8px rgba(0, 0, 0, 0.08);
        --sb-max-width: 960px;
        --sb-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --sb-sans: 'Inter', system-ui, -apple-system, sans-serif;
      }

      body {
        font-family: var(--sb-sans);
        background: var(--sb-bg);
        color: var(--sb-ink);
        margin: 0;
        overflow-x: clip;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Masthead ── */
      .sb-header {
        background: var(--sb-bg);
        padding: 24px 24px 12px;
        text-align: center;
        border-bottom: none;
      }
      .sb-header-inner {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        position: relative;
      }
      .sb-brand {
        text-decoration: none;
        color: var(--sb-ink);
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .sb-brand-icon { display: none; }

      /* ── Logo ── */
      .sb-logo { display: inline-block; user-select: none; }
      .sb-logo-main-row { display: flex; align-items: baseline; gap: 6px; }
      .sb-logo-the { font-family: var(--sb-serif); font-weight: 400; font-style: italic; font-size: 18px; color: var(--sb-ink); }
      .sb-logo-south-bay { font-family: var(--sb-serif); font-weight: 900; font-size: 40px; line-height: 1; color: var(--sb-ink); letter-spacing: -0.01em; }
      .sb-logo-signal-row { display: flex; align-items: center; gap: 8px; margin-top: 2px; }
      .sb-logo-signal-rule { flex: 1; height: 1px; background: var(--sb-ink); opacity: 0.35; }
      .sb-logo-signal-word { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: var(--sb-ink); }
      .sb-date {
        font-size: 12px;
        color: var(--sb-muted);
        font-weight: 400;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 4px;
      }
      .sb-slogan {
        font-family: var(--sb-sans);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--sb-light);
        margin-top: 6px;
      }
      .sb-masthead-rule { display: none; }

      /* ── Nav tabs ── */
      .sb-nav {
        background: var(--sb-bg);
        border-top: 1px solid var(--sb-border);
        border-bottom: 1px solid var(--sb-border);
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 99;
      }
      .sb-nav-inner {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        display: flex;
        justify-content: flex-start;
        gap: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }
      @media (min-width: 860px) {
        .sb-nav-inner { justify-content: center; }
      }
      .sb-nav-inner::-webkit-scrollbar { display: none; }
      .sb-nav-scroll-arrow {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 400;
        color: var(--sb-ink);
        background: linear-gradient(to right, transparent, var(--sb-bg) 40%);
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 2;
      }
      @media (min-width: 860px) {
        .sb-nav-scroll-arrow { display: none; }
      }
      .sb-tab {
        padding: 10px 14px;
        font-family: var(--sb-sans);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        border: none;
        background: none;
        cursor: pointer;
        white-space: nowrap;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
      }
      .sb-tab:hover { color: var(--sb-ink); }
      .sb-tab--active {
        color: var(--sb-ink);
        border-bottom-color: var(--sb-ink);
      }
      .sb-tab--disabled {
        color: var(--sb-light);
        cursor: default;
        position: relative;
      }
      .sb-tab--disabled::after {
        content: "soon";
        font-size: 8px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--sb-accent);
        margin-left: 6px;
        vertical-align: super;
      }

      /* ── Filter bar ── */
      .sb-filters {
        background: var(--sb-card);
        border-bottom: 1px solid var(--sb-border-light);
        padding: 12px 24px;
        overflow-x: clip;
      }
      .sb-filters-inner {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 6px 8px;
        flex-wrap: wrap;
      }
      @media (max-width: 640px) {
        .sb-filters {
          padding: 8px 16px;
        }
        .sb-filters-inner {
          flex-wrap: nowrap;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          mask-image: linear-gradient(to right, black calc(100% - 18px), transparent);
          -webkit-mask-image: linear-gradient(to right, black calc(100% - 18px), transparent);
          padding-right: 18px;
        }
        .sb-filters-inner::-webkit-scrollbar { display: none; }
        .sb-filters-inner > * { flex-shrink: 0; }
      }
      .sb-filter-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--sb-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-right: 4px;
      }
      .sb-city-pill {
        font-size: 11px;
        font-weight: 500;
        padding: 2px 9px;
        border-radius: 100px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--sb-light);
        cursor: pointer;
        transition: all 0.12s;
        white-space: nowrap;
      }
      .sb-city-pill:hover {
        color: var(--sb-ink);
      }
      .sb-city-pill--active {
        border-color: var(--sb-ink);
        color: var(--sb-ink);
        font-weight: 600;
        background: #fff;
      }
      .sb-city-pill--all {
        font-weight: 600;
      }

      /* Live now pulse — used by the Live filter pill in EventsView */
      @keyframes sb-live-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.45; }
      }

      /* ── Events page ── */
      .sb-events-page {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .sb-events-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 22px;
        align-items: end;
        padding: 0 0 24px;
        border-bottom: 3px double var(--sb-border);
      }
      .sb-events-eyebrow {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--sb-muted);
      }
      .sb-events-hero h1 {
        margin: 6px 0 10px;
        font-family: var(--sb-serif);
        font-size: 42px;
        line-height: 1;
        font-weight: 900;
        letter-spacing: 0;
        color: var(--sb-ink);
      }
      .sb-events-hero p {
        max-width: 700px;
        margin: 0;
        font-size: 15px;
        line-height: 1.65;
        color: var(--sb-muted);
      }
      .sb-events-hero-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(82px, 1fr));
        gap: 1px;
        border: 1px solid var(--sb-border-light);
        background: var(--sb-border-light);
        border-radius: 8px;
        overflow: hidden;
        min-width: 270px;
      }
      .sb-events-hero-stats span {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 12px 14px;
        background: #fff;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--sb-light);
      }
      .sb-events-hero-stats strong {
        font-family: var(--sb-serif);
        font-size: 23px;
        line-height: 1;
        color: var(--sb-ink);
        letter-spacing: 0;
      }
      .sb-events-controls {
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid var(--sb-border-light);
        border-radius: 8px;
        padding: 14px;
        box-shadow: 0 10px 28px rgba(26, 26, 26, 0.04);
      }
      .sb-events-nowline {
        display: grid;
        grid-template-columns: 40px minmax(0, 1fr) 40px;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
      }
      .sb-events-day-arrow {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: 1px solid var(--sb-border);
        background: #fff;
        color: var(--sb-ink);
        font-size: 17px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
      }
      .sb-events-day-arrow:hover:not(:disabled) {
        background: var(--sb-primary-light);
        border-color: var(--sb-ink);
      }
      .sb-events-day-arrow:disabled {
        opacity: 0.28;
        cursor: default;
      }
      .sb-events-nowline-text {
        text-align: center;
        min-width: 0;
      }
      .sb-events-mode-title {
        font-family: 'Space Mono', monospace;
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 0.08em;
        line-height: 1.1;
        color: var(--sb-ink);
        text-transform: uppercase;
      }
      .sb-events-mode-subtitle {
        margin-top: 3px;
        font-size: 12px;
        line-height: 1.35;
        color: var(--sb-muted);
      }
      .sb-events-date-rail {
        display: grid;
        grid-auto-columns: minmax(68px, 1fr);
        grid-auto-flow: column;
        gap: 8px;
        overflow-x: auto;
        padding: 2px 2px 10px;
        margin: 0 -2px 8px;
        scrollbar-width: thin;
        -webkit-overflow-scrolling: touch;
      }
      .sb-events-date-pill {
        position: relative;
        min-height: 70px;
        border: 1px solid var(--sb-border-light);
        border-radius: 8px;
        background: #fff;
        color: var(--sb-ink);
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        font-family: 'Space Mono', monospace;
        transition: border-color 0.15s, background 0.15s, color 0.15s, transform 0.15s;
      }
      .sb-events-date-pill:hover:not(:disabled) {
        border-color: var(--sb-ink);
        transform: translateY(-1px);
      }
      .sb-events-date-pill.is-active {
        background: var(--sb-ink);
        border-color: var(--sb-ink);
        color: #fff;
      }
      .sb-events-date-pill.is-empty:not(.is-active) {
        color: var(--sb-light);
        opacity: 0.58;
        cursor: default;
      }
      .sb-events-date-holiday {
        position: absolute;
        top: -6px;
        right: -2px;
        font-size: 13px;
      }
      .sb-events-date-weekday {
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 0.08em;
      }
      .sb-events-date-number {
        font-size: 22px;
        font-weight: 800;
        line-height: 1;
      }
      .sb-events-date-count {
        min-width: 22px;
        padding: 1px 7px;
        border-radius: 999px;
        background: var(--sb-primary-light);
        color: var(--sb-ink);
        font-size: 10px;
        font-weight: 800;
        line-height: 15px;
      }
      .sb-events-date-pill.is-active .sb-events-date-count {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
      }
      .sb-events-toolrow {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(170px, 220px) auto;
        gap: 10px;
        align-items: stretch;
      }
      .sb-events-search,
      .sb-events-select-wrap,
      .sb-events-refine summary {
        min-height: 42px;
        box-sizing: border-box;
        border: 1px solid var(--sb-border-light);
        border-radius: 8px;
        background: #fff;
      }
      .sb-events-search {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 9px;
        padding: 0 12px;
      }
      .sb-events-search-icon,
      .sb-events-select-wrap > span {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--sb-light);
      }
      .sb-events-search input {
        width: 100%;
        border: 0;
        outline: 0;
        padding: 10px 0;
        font: inherit;
        font-size: 14px;
        color: var(--sb-ink);
        background: transparent;
        min-width: 0;
      }
      .sb-events-search:focus-within,
      .sb-events-select-wrap:focus-within,
      .sb-events-refine[open] summary {
        border-color: var(--sb-ink);
        box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.06);
      }
      .sb-events-select-wrap {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 9px;
        padding: 0 10px 0 12px;
      }
      .sb-events-select {
        min-width: 0;
        border: 0;
        outline: 0;
        background: transparent;
        color: var(--sb-ink);
        font: inherit;
        font-size: 13px;
        font-weight: 600;
      }
      .sb-events-refine {
        position: relative;
        min-width: 180px;
      }
      .sb-events-refine summary {
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        font-size: 13px;
        font-weight: 700;
        color: var(--sb-ink);
        cursor: pointer;
        white-space: nowrap;
      }
      .sb-events-refine summary::-webkit-details-marker { display: none; }
      .sb-events-refine summary::after {
        content: "";
        width: 7px;
        height: 7px;
        border-right: 1.5px solid currentColor;
        border-bottom: 1.5px solid currentColor;
        transform: rotate(45deg) translateY(-2px);
        margin-left: 10px;
        opacity: 0.55;
      }
      .sb-events-refine[open] summary::after {
        transform: rotate(225deg) translateY(-2px);
      }
      .sb-events-city-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        width: min(560px, 88vw);
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 12px;
        background: #fff;
        border: 1px solid var(--sb-border);
        border-radius: 8px;
        box-shadow: 0 18px 44px rgba(26, 26, 26, 0.14);
        z-index: 30;
      }
      .sb-events-city-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 30px;
        border: 1px solid var(--sb-border-light);
        border-radius: 999px;
        background: #fff;
        color: var(--sb-muted);
        padding: 5px 10px;
        font: inherit;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
      }
      .sb-events-city-chip.is-active {
        border-color: var(--sb-ink);
        color: var(--sb-ink);
        background: var(--sb-primary-light);
      }
      .sb-events-city-chip span,
      .sb-events-toggle span {
        min-width: 18px;
        padding: 1px 6px;
        border-radius: 999px;
        background: #fff;
        color: inherit;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 800;
        line-height: 15px;
        text-align: center;
      }
      .sb-events-toggle-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        margin-top: 10px;
      }
      .sb-events-toggle,
      .sb-events-clear {
        --toggle-accent: var(--sb-ink);
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 32px;
        border: 1px solid var(--sb-border-light);
        border-radius: 999px;
        background: #fff;
        color: var(--sb-muted);
        padding: 5px 12px;
        font: inherit;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
      }
      .sb-events-toggle:hover,
      .sb-events-clear:hover {
        border-color: var(--sb-ink);
        color: var(--sb-ink);
      }
      .sb-events-toggle.is-active {
        border-color: var(--toggle-accent);
        background: var(--toggle-accent);
        color: #fff;
      }
      .sb-events-toggle.is-active span {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
      }
      .sb-events-toggle--live::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        animation: sb-live-pulse 1.6s ease-in-out infinite;
      }
      .sb-events-clear {
        margin-left: auto;
        color: var(--sb-accent);
        border-color: #F1C7C1;
      }
      .sb-events-results,
      .sb-events-exhibits {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .sb-events-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .sb-events-group-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 7px;
        border-bottom: 1px solid var(--sb-border);
      }
      .sb-events-group-header span {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--sb-ink);
      }
      .sb-events-group-header small {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        color: var(--sb-light);
      }
      .sb-events-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .sb-events-active-note {
        --note-bg: #fff;
        --note-color: var(--sb-ink);
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        margin-bottom: 2px;
        background: var(--note-bg);
        border: 1px solid color-mix(in srgb, var(--note-color) 28%, transparent);
        border-radius: 8px;
        color: var(--note-color);
        font-size: 12px;
      }
      .sb-events-active-note button {
        margin-left: auto;
        border: 1px solid currentColor;
        border-radius: 999px;
        background: #fff;
        color: inherit;
        padding: 3px 9px;
        font: inherit;
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
      }
      .sb-event-card {
        --event-accent: var(--sb-ink);
        --event-accent-bg: var(--sb-primary-light);
        display: grid;
        grid-template-columns: 112px minmax(0, 1fr);
        min-height: 132px;
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--sb-border-light);
        border-radius: 8px;
        box-shadow: inset 4px 0 0 var(--event-accent);
        transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
      }
      .sb-event-card:hover {
        border-color: var(--sb-border);
        box-shadow: inset 4px 0 0 var(--event-accent), 0 12px 28px rgba(26, 26, 26, 0.08);
        transform: translateY(-1px);
      }
      .sb-event-card-photo {
        width: 100%;
        height: 100%;
        min-height: 132px;
        object-fit: cover;
        background: var(--event-accent-bg);
        border-right: 1px solid var(--sb-border-light);
      }
      .sb-event-card-photo--fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--event-accent);
        font-size: 34px;
      }
      .sb-event-card-body {
        min-width: 0;
        padding: 14px 16px 12px;
      }
      .sb-event-card-kicker {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 5px;
        font-family: 'Space Mono', monospace;
        font-size: 9.5px;
        font-weight: 800;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }
      .sb-event-micro-badge {
        display: inline-flex;
        align-items: center;
        min-height: 16px;
        border: 1px solid currentColor;
        border-radius: 999px;
        padding: 0 6px;
        font-size: 9px;
        line-height: 14px;
      }
      .sb-event-card-title {
        margin: 0;
        color: var(--sb-ink);
        font-family: var(--sb-serif);
        font-size: 18px;
        font-weight: 800;
        line-height: 1.22;
      }
      .sb-event-card-title a {
        color: inherit;
        text-decoration: none;
      }
      .sb-event-card-title a:hover { text-decoration: underline; }
      .sb-event-card-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 3px 8px;
        margin-top: 5px;
        font-size: 11.5px;
        line-height: 1.45;
        color: var(--sb-muted);
      }
      .sb-event-card-time {
        color: var(--sb-ink);
        font-weight: 800;
      }
      .sb-event-date-chip,
      .sb-event-recurring {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--sb-border-light);
        border-radius: 999px;
        background: var(--sb-primary-light);
        color: var(--sb-ink);
        padding: 1px 7px;
        font-family: 'Space Mono', monospace;
        font-size: 9.5px;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .sb-event-recurring {
        background: #F5F3FF;
        border-color: #DDD6FE;
        color: #6D28D9;
      }
      .sb-event-card-copy {
        margin: 7px 0 0;
        font-size: 12.5px;
        line-height: 1.55;
        color: var(--sb-muted);
      }
      .sb-event-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 9px;
      }
      .sb-event-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 25px;
        padding: 4px 9px;
        border: 1px solid var(--sb-border-light);
        border-radius: 999px;
        background: #fff;
        color: var(--sb-muted);
        font-family: 'Space Mono', monospace;
        font-size: 9.5px;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
      }
      .sb-event-action:hover {
        border-color: var(--sb-ink);
        color: var(--sb-ink);
        background: var(--sb-primary-light);
      }
      .sb-event-action--done {
        color: #15803D;
        border-color: #BBF7D0;
        background: #F0FDF4;
      }
      @media (max-width: 760px) {
        .sb-events-hero {
          grid-template-columns: 1fr;
          gap: 14px;
        }
        .sb-events-hero h1 { font-size: 34px; }
        .sb-events-hero-stats {
          width: 100%;
          min-width: 0;
        }
        .sb-events-toolrow {
          grid-template-columns: 1fr;
        }
        .sb-events-refine {
          min-width: 0;
        }
        .sb-events-refine summary {
          justify-content: space-between;
        }
        .sb-events-city-panel {
          left: 0;
          right: auto;
          width: min(100%, 560px);
          box-sizing: border-box;
        }
      }
      @media (max-width: 640px) {
        .sb-events-page { gap: 14px; }
        .sb-events-controls {
          margin-left: -8px;
          margin-right: -8px;
          padding: 12px;
        }
        .sb-events-nowline {
          grid-template-columns: 34px minmax(0, 1fr) 34px;
          gap: 7px;
        }
        .sb-events-day-arrow {
          width: 34px;
          height: 34px;
        }
        .sb-events-mode-title { font-size: 15px; }
        .sb-events-date-rail {
          grid-auto-columns: 66px;
        }
        .sb-events-toggle-row {
          flex-wrap: nowrap;
          overflow-x: auto;
          padding-bottom: 2px;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
        }
        .sb-events-toggle-row::-webkit-scrollbar { display: none; }
        .sb-events-toggle-row > * { flex: 0 0 auto; }
        .sb-events-clear { margin-left: 0; }
        .sb-event-card {
          grid-template-columns: 86px minmax(0, 1fr);
          min-height: 118px;
          border-radius: 7px;
        }
        .sb-event-card-photo {
          min-height: 118px;
        }
        .sb-event-card-body {
          padding: 11px 12px 10px;
        }
        .sb-event-card-title {
          font-size: 15.5px;
        }
        .sb-event-card-copy {
          font-size: 12px;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
        .sb-event-card-actions {
          gap: 5px;
        }
        .sb-event-action {
          font-size: 9px;
          padding: 3px 7px;
        }
      }

      /* ── Content area ── */
      .sb-main {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        padding: 24px;
      }

      /* ── Editorial page hero ── */
      .sb-page-hero {
        display: flex;
        flex-direction: column;
        gap: 22px;
        padding-bottom: 24px;
        border-bottom: 3px double var(--sb-border);
      }
      .sb-page-hero-copy {
        max-width: 760px;
      }
      .sb-page-kicker {
        color: var(--sb-muted);
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .sb-page-title {
        margin: 6px 0 10px;
        color: var(--sb-ink);
        font-family: var(--sb-serif);
        font-size: 42px;
        font-weight: 900;
        letter-spacing: 0;
        line-height: 1;
      }
      .sb-page-subtitle {
        max-width: 760px;
        margin: 0;
        color: var(--sb-muted);
        font-size: 15px;
        line-height: 1.65;
      }
      .sb-page-note {
        margin-top: 10px;
        color: var(--sb-light);
        font-size: 11px;
        letter-spacing: 0.03em;
      }
      .sb-page-stats {
        display: grid;
        grid-template-columns: repeat(var(--sb-page-stat-count), minmax(0, 1fr));
        width: 100%;
        border: 1px solid var(--sb-border-light);
        background: var(--sb-card);
      }
      .sb-page-stat {
        min-width: 0;
        padding: 15px 16px;
        border-left: 1px solid var(--sb-border-light);
      }
      .sb-page-stat:first-child {
        border-left: none;
      }
      .sb-page-stat strong {
        display: block;
        color: var(--sb-ink);
        font-family: var(--sb-serif);
        font-size: 28px;
        line-height: 1;
      }
      .sb-page-stat span {
        display: block;
        margin-top: 5px;
        color: var(--sb-muted);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .sb-page-stat p {
        margin: 5px 0 0;
        color: var(--sb-light);
        font-size: 11px;
        line-height: 1.4;
      }

      /* ── Section headers ── */
      .sb-section-header {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 20px;
        border-bottom: 1px solid var(--sb-border);
        padding-bottom: 8px;
      }
      .sb-section-title {
        font-family: var(--sb-serif);
        font-size: 22px;
        font-weight: 700;
        text-transform: none;
        letter-spacing: -0.01em;
        color: var(--sb-ink);
      }
      .sb-section-line {
        display: none;
      }
      .sb-league-group {
        margin-bottom: 28px;
      }
      .sb-league-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--sb-muted);
        margin-bottom: 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid var(--sb-border-light);
      }

      /* ── Game cards ── */
      .sb-games-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 480px));
        gap: 0;
        border-top: 1px solid var(--sb-border-light);
      }
      .sb-game-card {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        border-top: none;
        border-radius: 0;
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: background 0.15s;
      }
      .sb-game-card:first-child {
        border-top: 1px solid var(--sb-border-light);
      }
      .sb-game-card:hover {
        background: var(--sb-primary-light);
        box-shadow: none;
      }
      .sb-game-card--live {
        border-left: 3px solid var(--sb-live);
        padding-left: 13px;
      }
      .sb-game-status {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .sb-game-time {
        font-size: 12px;
        font-weight: 500;
        color: var(--sb-muted);
      }
      .sb-live-badge {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--sb-live);
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .sb-live-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sb-live);
        animation: sb-pulse 2s infinite;
      }
      @keyframes sb-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
      .sb-broadcast {
        font-size: 11px;
        color: var(--sb-light);
        font-weight: 500;
      }
      .sb-game-teams {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .sb-team-row {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .sb-team-logo {
        width: 24px;
        height: 24px;
        object-fit: contain;
        flex-shrink: 0;
      }
      .sb-team-name {
        flex: 1;
        font-size: 14px;
        font-weight: 600;
        color: var(--sb-ink);
      }
      .sb-team-name--south-bay {
        color: var(--sb-primary);
      }
      .sb-team-record {
        font-size: 12px;
        color: var(--sb-light);
        font-weight: 400;
        margin-left: 4px;
      }
      .sb-team-score {
        font-family: 'Space Mono', monospace;
        font-size: 18px;
        font-weight: 700;
        min-width: 32px;
        text-align: right;
      }
      .sb-team-score--winner { color: var(--sb-ink); }
      .sb-team-score--loser { color: var(--sb-light); }

      /* ── Overview placeholders ── */
      .sb-overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
        border-radius: var(--sb-radius);
        overflow: hidden;
      }
      .sb-overview-section {
        background: var(--sb-card);
        padding: 24px;
      }
      .sb-overview-section h3 {
        font-family: var(--sb-serif);
        font-size: 16px;
        font-weight: 700;
        text-transform: none;
        letter-spacing: 0;
        color: var(--sb-ink);
        margin: 0 0 8px 0;
      }

      /* ── Live urgency pill (Happening Now / Starts in N min) ── */
      @keyframes sbUrgencyPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.45); }
        50%      { box-shadow: 0 0 0 4px rgba(220, 38, 38, 0); }
      }
      .sb-urgency-pulse {
        animation: sbUrgencyPulse 1.8s ease-in-out infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        .sb-urgency-pulse { animation: none; }
      }

      /* ── Empty / loading states ── */
      .sb-empty {
        text-align: center;
        padding: 48px 24px;
        color: var(--sb-muted);
      }
      .sb-empty-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 4px;
      }
      .sb-empty-sub {
        font-size: 13px;
        color: var(--sb-light);
      }
      .sb-loading {
        text-align: center;
        padding: 48px 24px;
      }
      .sb-spinner {
        width: 28px;
        height: 28px;
        border: 3px solid var(--sb-border-light);
        border-top-color: var(--sb-primary);
        border-radius: 50%;
        animation: sb-spin 0.7s linear infinite;
        margin: 0 auto 12px;
      }
      @keyframes sb-spin {
        to { transform: rotate(360deg); }
      }
      .sb-loading-text {
        font-size: 13px;
        color: var(--sb-muted);
      }

      /* ── Digest cards ── */
      .sb-digest-card {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        padding: 24px;
        margin-bottom: 16px;
      }
      .sb-digest-header {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 4px;
      }
      .sb-digest-city {
        font-family: var(--sb-serif);
        font-size: 18px;
        font-weight: 700;
        color: var(--sb-ink);
      }
      .sb-digest-body {
        font-size: 12px;
        color: var(--sb-light);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
      }
      .sb-digest-date {
        font-size: 13px;
        color: var(--sb-muted);
        margin-bottom: 12px;
      }
      .sb-digest-summary {
        font-size: 14px;
        line-height: 1.6;
        color: var(--sb-ink);
        margin: 0 0 12px 0;
      }
      .sb-digest-topics {
        margin: 0 0 16px 0;
        padding-left: 18px;
        font-size: 13px;
        line-height: 1.7;
        color: var(--sb-muted);
      }
      .sb-digest-topics li { margin-bottom: 2px; }
      .sb-digest-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--sb-border-light);
      }
      .sb-digest-next {
        color: var(--sb-muted);
      }
      .sb-digest-source {
        color: var(--sb-muted);
        text-decoration: none;
        font-weight: 500;
      }
      .sb-digest-source:hover { text-decoration: underline; }
      .sb-digest-loading {
        text-align: center;
        padding: 32px;
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        margin-bottom: 16px;
      }
      .sb-digest-error {
        padding: 16px 20px;
        background: var(--sb-accent-light);
        border: 1px solid var(--sb-border-light);
        margin-bottom: 16px;
        font-size: 13px;
        color: var(--sb-accent);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .sb-digest-error button {
        padding: 4px 12px;
        background: none;
        border: 1px solid var(--sb-accent);
        color: var(--sb-accent);
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
      }
      .sb-gov-upcoming {
        padding: 20px;
        font-size: 13px;
        color: var(--sb-muted);
        text-align: center;
      }

      /* ── Government section blurb ── */
      .gov-section-blurb {
        font-size: 13px;
        color: var(--sb-muted);
        margin: 0 0 14px 0;
        line-height: 1.55;
        max-width: 620px;
      }

      /* ── Council Digest Turnstile ── */
      .cdt-wrap { outline: none; }
      .cdt-wrap:focus-visible {
        outline: 2px solid var(--sb-ink);
        outline-offset: 4px;
        border-radius: 4px;
      }
      .cdt-chips {
        display: flex;
        gap: 6px;
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        padding: 2px 4px 12px;
        margin: 0 -4px 4px;
      }
      .cdt-chips::-webkit-scrollbar { display: none; }
      .cdt-chip {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-family: var(--sb-sans);
        font-size: 12px;
        font-weight: 600;
        padding: 5px 12px;
        border: 1px solid var(--sb-border);
        background: var(--sb-card);
        color: var(--sb-muted);
        border-radius: 100px;
        cursor: pointer;
        white-space: nowrap;
        transition: border-color 0.12s, color 0.12s, background 0.12s;
      }
      .cdt-chip:hover { border-color: var(--sb-ink); color: var(--sb-ink); }
      .cdt-chip--active { font-weight: 700; }
      .cdt-chip-dot {
        font-weight: 700;
        opacity: 0.5;
        margin-left: 2px;
        font-size: 13px;
        line-height: 0.8;
      }
      .cdt-stage {
        display: grid;
        grid-template-columns: 36px 1fr 36px;
        gap: 4px;
        align-items: stretch;
        margin-bottom: 8px;
      }
      .cdt-arrow {
        background: transparent;
        border: 1px solid var(--sb-border-light);
        border-radius: 4px;
        cursor: pointer;
        font-size: 22px;
        line-height: 1;
        color: var(--sb-muted);
        transition: background 0.12s, color 0.12s, border-color 0.12s;
        font-family: var(--sb-serif);
        padding: 0;
      }
      .cdt-arrow:hover:not(:disabled) {
        background: var(--sb-primary-light);
        color: var(--sb-ink);
        border-color: var(--sb-border);
      }
      .cdt-arrow:disabled { opacity: 0.3; cursor: default; }
      .cdt-card-wrap { min-height: 220px; display: flex; }
      .cdt-card {
        flex: 1;
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        border-radius: 6px;
        padding: 22px 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        animation: cdt-fade 0.22s ease-out;
      }
      @keyframes cdt-fade {
        from { opacity: 0; transform: translateY(2px); }
        to   { opacity: 1; transform: none; }
      }
      .cdt-loading,
      .cdt-error {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: var(--sb-muted);
        padding: 32px 8px;
      }
      .cdt-error { color: var(--sb-accent); flex-wrap: wrap; }
      .cdt-retry {
        margin-left: auto;
        padding: 4px 12px;
        font-size: 12px;
        font-weight: 600;
        background: transparent;
        border: 1px solid var(--sb-accent);
        color: var(--sb-accent);
        border-radius: 3px;
        cursor: pointer;
      }
      .cdt-header { display: flex; flex-direction: column; gap: 2px; }
      .cdt-eyebrow {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 2px;
      }
      .cdt-title {
        font-family: var(--sb-serif);
        font-size: 24px;
        font-weight: 800;
        color: var(--sb-ink);
        margin: 0;
        letter-spacing: -0.01em;
        line-height: 1.15;
      }
      .cdt-date {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--sb-muted);
        margin-top: 2px;
      }
      .cdt-stale-tag {
        font-family: 'Space Mono', monospace;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
        padding: 2px 6px;
        border-radius: 3px;
      }
      .cdt-summary {
        font-size: 14px;
        line-height: 1.6;
        color: var(--sb-ink);
        margin: 4px 0 2px;
      }
      .cdt-summary--muted { color: var(--sb-muted); }
      .cdt-topics {
        margin: 0;
        padding-left: 18px;
        font-size: 13px;
        line-height: 1.65;
        color: var(--sb-muted);
      }
      .cdt-topics li { margin-bottom: 1px; }
      .cdt-next {
        margin-top: 6px;
        padding: 12px 14px;
        background: var(--sb-primary-light);
        border-radius: 4px;
      }
      .cdt-next-label {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--sb-muted);
        margin-bottom: 6px;
      }
      .cdt-next-items {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .cdt-next-items li {
        font-size: 12px;
        color: var(--sb-ink);
        line-height: 1.4;
        padding-left: 10px;
        border-left: 2px solid var(--sb-border);
      }
      .cdt-next-link { font-size: 12px; font-weight: 600; text-decoration: none; }
      .cdt-next-link:hover { text-decoration: underline; }
      .cdt-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: auto;
        padding-top: 12px;
        border-top: 1px solid var(--sb-border-light);
      }
      .cdt-source { font-size: 12px; font-weight: 600; text-decoration: none; }
      .cdt-source:hover { text-decoration: underline; }
      .cdt-refresh {
        padding: 4px 10px;
        font-size: 11px;
        font-family: 'Space Mono', monospace;
        background: transparent;
        border: 1px solid var(--sb-border);
        color: var(--sb-muted);
        border-radius: 3px;
        cursor: pointer;
        transition: border-color 0.12s, color 0.12s;
      }
      .cdt-refresh:hover { border-color: var(--sb-ink); color: var(--sb-ink); }
      .cdt-refresh--primary {
        background: var(--sb-ink);
        color: #fff;
        border-color: var(--sb-ink);
        font-weight: 700;
      }
      .cdt-refresh--primary:hover { opacity: 0.9; color: #fff; }
      .cdt-counter {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        color: var(--sb-muted);
        padding: 2px 4px;
      }
      .cdt-counter-sep { color: var(--sb-border); }
      @media (max-width: 640px) {
        .cdt-stage { grid-template-columns: 28px 1fr 28px; }
        .cdt-arrow { font-size: 18px; }
        .cdt-card { padding: 18px 16px 16px; }
        .cdt-title { font-size: 20px; }
        .cdt-summary { font-size: 13px; }
      }

      /* ── Coming soon state ── */
      .sb-coming-soon {
        text-align: center;
        padding: 64px 24px;
      }
      .sb-coming-soon-icon {
        font-size: 28px;
        margin-bottom: 12px;
        opacity: 0.5;
      }
      .sb-coming-soon-title {
        font-family: var(--sb-serif);
        font-size: 20px;
        font-weight: 700;
        color: var(--sb-ink);
        margin-bottom: 4px;
      }
      .sb-coming-soon-sub {
        font-size: 13px;
        color: var(--sb-muted);
      }

      /* ── Technology section ── */
      .tech-view {
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      /* Header */
      .tech-header {
        border-bottom: 3px double var(--sb-border);
        padding-bottom: 24px;
      }
      .tech-header-eyebrow {
        font-family: 'Space Mono', monospace;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--sb-muted);
      }
      .tech-header-title {
        font-family: var(--sb-serif);
        font-size: 42px;
        font-weight: 900;
        letter-spacing: 0;
        color: var(--sb-ink);
        margin: 6px 0 10px;
        line-height: 1;
      }
      .tech-header-subtitle {
        font-size: 15px;
        color: var(--sb-muted);
        margin: 0;
        line-height: 1.65;
        max-width: 700px;
      }
      .tech-header-note {
        font-size: 11px;
        color: var(--sb-light);
        letter-spacing: 0.03em;
        margin-top: 10px;
      }

      /* Pulse strip */
      .tech-pulse {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
      }
      .tech-pulse-item {
        background: var(--sb-card);
        padding: 16px 20px;
      }
      .tech-pulse-value {
        font-family: var(--sb-serif);
        font-size: 22px;
        font-weight: 800;
        color: var(--sb-ink);
        line-height: 1.1;
        margin-bottom: 3px;
      }
      .tech-pulse-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }
      .tech-pulse-note {
        font-size: 12px;
        color: var(--sb-light);
        line-height: 1.4;
      }

      /* Section wrapper */
      .tech-section {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .tech-section-head {
        display: flex;
        align-items: baseline;
        gap: 12px;
        border-bottom: 1px solid var(--sb-border);
        padding-bottom: 8px;
      }
      .tech-section-title {
        font-family: var(--sb-serif);
        font-size: 20px;
        font-weight: 700;
        color: var(--sb-ink);
        margin: 0;
      }
      .tech-section-note {
        font-size: 12px;
        color: var(--sb-light);
      }

      /* Chart */
      .tech-chart-wrap {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        padding: 20px 8px 12px 0;
      }
      .tech-chart-legend {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 11px;
      }
      .tech-legend-up { color: #16a34a; font-weight: 600; }
      .tech-legend-down { color: #dc2626; font-weight: 600; }
      .tech-legend-note { color: var(--sb-light); margin-left: auto; }

      /* Category / city filter pills */
      .tech-filter-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 10px 0 12px;
      }
      .tech-filter-pill {
        font-family: var(--sb-sans);
        font-size: 12px;
        font-weight: 500;
        padding: 4px 10px;
        border: 1px solid var(--sb-border);
        border-radius: 20px;
        background: var(--sb-card);
        color: var(--sb-ink);
        cursor: pointer;
        transition: background 0.12s, color 0.12s, border-color 0.12s;
        line-height: 1.4;
      }
      .tech-filter-pill:hover {
        background: var(--sb-primary-light);
        border-color: var(--sb-primary);
      }
      .tech-filter-pill--active {
        background: var(--sb-primary);
        border-color: var(--sb-primary);
        color: #fff;
      }
      .tech-filter-pill--active:hover {
        background: var(--sb-primary);
      }
      .tech-filter-empty {
        font-size: 13px;
        color: var(--sb-light);
        padding: 16px 0;
        grid-column: 1 / -1;
      }

      /* ── Weekly briefing card ────────────────────────────────────────── */
      .tech-briefing {
        padding: 14px 16px;
        background: var(--sb-cream, #fdf8f0);
        border: 1px solid var(--sb-border-light);
        border-left: 4px solid #7c3aed;
        border-radius: 6px;
      }
      .tech-briefing-head {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 8px;
        flex-wrap: wrap;
      }
      .tech-briefing-eyebrow {
        font-size: 10px;
        font-weight: 700;
        font-family: 'Space Mono', monospace;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #7c3aed;
      }
      .tech-briefing-week {
        font-size: 10px;
        color: var(--sb-muted);
        font-family: 'Space Mono', monospace;
      }
      .tech-briefing-body {
        margin: 0;
        font-size: 13px;
        line-height: 1.6;
        color: var(--sb-ink);
      }

      /* ── Funding ticker ──────────────────────────────────────────────── */
      .tech-ticker {
        display: flex;
        align-items: stretch;
        background: linear-gradient(180deg, #faf5ff 0%, #f5f3ff 100%);
        border: 1px solid #ddd6fe;
        border-radius: 6px;
        overflow: hidden;
      }
      .tech-ticker-label {
        padding: 12px 14px;
        font-size: 10px;
        font-weight: 700;
        font-family: 'Space Mono', monospace;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6b21a8;
        background: rgba(255,255,255,0.5);
        border-right: 1px solid #ddd6fe;
        align-self: stretch;
        display: flex;
        align-items: center;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .tech-ticker-viewport {
        flex: 1;
        overflow: hidden;
        position: relative;
        min-width: 0;
        mask-image: linear-gradient(90deg, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%);
        -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%);
      }
      .tech-ticker-track {
        display: inline-flex;
        gap: 0;
        animation: tech-ticker-scroll 60s linear infinite;
        will-change: transform;
      }
      .tech-ticker-viewport:hover .tech-ticker-track,
      .tech-ticker-track:focus-within {
        animation-play-state: paused;
      }
      @keyframes tech-ticker-scroll {
        from { transform: translate3d(0, 0, 0); }
        to { transform: translate3d(-50%, 0, 0); }
      }
      @media (prefers-reduced-motion: reduce) {
        .tech-ticker-track { animation: none; }
        .tech-ticker-viewport {
          overflow-x: auto;
          mask-image: none;
          -webkit-mask-image: none;
        }
      }
      .tech-ticker-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-right: 1px solid #ede9fe;
        text-decoration: none;
        color: inherit;
        white-space: nowrap;
        transition: background 0.12s;
      }
      .tech-ticker-item:hover { background: rgba(255,255,255,0.6); }
      .tech-ticker-text { display: flex; flex-direction: column; gap: 1px; }
      .tech-ticker-name {
        font-family: var(--sb-sans);
        font-size: 12px;
        font-weight: 700;
        color: var(--sb-ink);
        line-height: 1.1;
      }
      .tech-ticker-meta {
        display: flex;
        gap: 6px;
        font-size: 10px;
        font-family: 'Space Mono', monospace;
        line-height: 1.2;
      }
      .tech-ticker-amount { color: #15803d; font-weight: 700; }
      .tech-ticker-round { color: #6b21a8; }

      /* ── Top Employers Leaderboard ──────────────────────────────────── */
      .tech-leaderboard {
        display: flex;
        flex-direction: column;
        gap: 4px;
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        border-radius: 6px;
        padding: 8px;
      }
      .tech-leaderboard-row {
        display: grid;
        grid-template-columns: 28px 36px minmax(140px, 1fr) minmax(80px, 2.2fr) 70px;
        align-items: center;
        gap: 10px;
        padding: 6px 8px;
        text-decoration: none;
        color: inherit;
        border-radius: 4px;
        transition: background 0.12s;
      }
      .tech-leaderboard-row:hover {
        background: var(--sb-primary-light, #f5f3ff);
      }
      .tech-leaderboard-rank {
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        color: var(--sb-light);
        text-align: center;
      }
      .tech-leaderboard-info {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .tech-leaderboard-name {
        font-family: var(--sb-sans);
        font-size: 13px;
        font-weight: 700;
        color: var(--sb-ink);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .tech-leaderboard-arrow-out {
        font-size: 10px;
        color: var(--sb-light);
        margin-left: 4px;
      }
      .tech-leaderboard-meta {
        font-size: 11px;
        color: var(--sb-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .tech-leaderboard-bar-wrap {
        position: relative;
        height: 10px;
        background: var(--sb-border-light);
        border-radius: 5px;
        overflow: hidden;
      }
      .tech-leaderboard-bar {
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        border-radius: 5px;
        transition: width 0.4s ease;
      }
      .tech-leaderboard-num {
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--sb-ink);
        text-align: right;
        display: flex;
        align-items: baseline;
        justify-content: flex-end;
        gap: 4px;
      }
      .tech-leaderboard-num-value { font-size: 13px; }
      .tech-leaderboard-arrow { font-size: 11px; }
      .tech-leaderboard-footnote {
        padding: 8px 10px 4px;
        font-size: 10px;
        color: var(--sb-light);
        font-style: italic;
        border-top: 1px solid var(--sb-border-light);
        margin-top: 6px;
      }

      /* ── SV History milestones ───────────────────────────────────────── */
      .tech-milestone {
        display: flex;
        gap: 14px;
        padding: 14px 16px;
        background: #fdf8f0;
        border: 1px solid var(--sb-border-light);
        border-left: 4px solid #b45309;
        border-radius: 6px;
        align-items: flex-start;
      }
      .tech-milestone--upcoming {
        background: #f9fafb;
        border-left-color: #9ca3af;
      }
      .tech-milestone-top {
        display: flex;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 4px;
      }
      .tech-milestone-name {
        font-size: 14px;
        font-weight: 700;
        color: var(--sb-ink);
        font-family: var(--sb-sans);
      }
      .tech-milestone-pill {
        font-size: 10px;
        font-weight: 700;
        font-family: 'Space Mono', monospace;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 2px 7px;
        border-radius: 3px;
      }
      .tech-milestone-pill--amber {
        color: #b45309;
        background: #fef3c7;
      }
      .tech-milestone-pill--gray {
        color: #6b7280;
        background: #f3f4f6;
      }
      .tech-milestone-loc {
        font-size: 11px;
        color: var(--sb-muted);
        font-family: var(--sb-sans);
      }
      .tech-milestone-note {
        margin: 0 0 6px;
        font-size: 13px;
        line-height: 1.55;
        color: var(--sb-ink);
      }
      .tech-milestone-chm {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: #1d4ed8;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 4px;
        padding: 3px 8px;
        margin-top: 2px;
      }

      /* ── Recently funded row ─────────────────────────────────────────── */
      .tech-funded-row {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 14px 0;
        border-bottom: 1px solid var(--sb-border-light);
        text-decoration: none;
        color: inherit;
        transition: background 0.12s;
      }
      .tech-funded-row:hover {
        background: var(--sb-primary-light, #f5f3ff);
      }

      /* Company grid */
      .tech-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
      }

      /* Company card */
      .tech-card {
        background: var(--sb-card);
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        border: 1px solid var(--sb-border-light);
        border-radius: 8px;
        transition: box-shadow 0.15s, transform 0.15s;
      }
      .tech-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transform: translateY(-1px);
      }
      .tech-card-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: flex-start;
        gap: 12px;
      }
      .tech-card-id {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 3px;
      }
      .tech-card-name-row {
        display: flex;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
      }
      .tech-card-name {
        font-family: var(--sb-serif);
        font-size: 18px;
        font-weight: 700;
        color: var(--sb-ink);
        line-height: 1.2;
      }
      .tech-card-ticker {
        font-size: 11px;
        font-weight: 600;
        color: var(--sb-light);
        letter-spacing: 0.04em;
        font-family: 'Space Mono', monospace;
      }
      .tech-card-meta {
        display: flex;
        align-items: center;
        gap: 5px;
        flex-wrap: wrap;
        font-size: 12px;
        color: var(--sb-muted);
      }
      .tech-card-city { font-weight: 500; }
      .tech-card-dot { color: var(--sb-border); }
      .tech-card-category {
        background: var(--sb-primary-light);
        border: 1px solid var(--sb-border-light);
        padding: 1px 6px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--sb-muted);
      }
      .tech-card-stat {
        display: flex;
        align-items: baseline;
        gap: 6px;
        padding: 6px 10px;
        background: var(--sb-primary-light, #f5f3ff);
        border-radius: 4px;
        align-self: flex-start;
      }
      .tech-card-stat-value {
        font-family: 'Space Mono', monospace;
        font-size: 16px;
        font-weight: 700;
        color: var(--sb-ink);
      }
      .tech-card-stat-label {
        font-size: 10px;
        color: var(--sb-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-family: 'Space Mono', monospace;
      }
      .tech-card-desc {
        font-size: 13px;
        color: var(--sb-ink);
        line-height: 1.5;
        margin: 0;
      }
      .tech-card-trend-note {
        font-size: 12px;
        color: var(--sb-muted);
        font-style: italic;
      }
      .tech-card-highlights {
        margin: 4px 0 0 0;
        padding-left: 16px;
        font-size: 12px;
        color: var(--sb-muted);
        line-height: 1.6;
      }
      .tech-card-highlights li { margin-bottom: 2px; }

      /* Trend badges */
      .tech-trend {
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
        padding: 2px 6px;
        border-radius: 2px;
        flex-shrink: 0;
      }
      .tech-trend--up {
        color: #15803d;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
      }
      .tech-trend--down {
        color: #b91c1c;
        background: #fef2f2;
        border: 1px solid #fecaca;
      }
      .tech-trend--flat {
        color: var(--sb-muted);
        background: var(--sb-primary-light);
        border: 1px solid var(--sb-border-light);
      }

      /* Spotlight grid */
      .tech-spotlight-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
      }

      .tech-spotlight-card {
        background: var(--sb-card);
        border: 1px solid var(--sb-border);
        border-radius: 6px;
        padding: 14px 14px 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.15s, transform 0.15s;
      }
      .tech-spotlight-card:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transform: translateY(-1px);
      }

      .tech-spotlight-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 10px;
      }
      .tech-spotlight-id {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .tech-spotlight-name {
        font-size: 13px;
        font-weight: 700;
        color: var(--sb-ink);
        font-family: var(--sb-sans);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .tech-spotlight-arrow {
        font-size: 10px;
        color: var(--sb-light);
        margin-left: 2px;
      }
      .tech-spotlight-meta {
        font-size: 11px;
        color: var(--sb-muted);
        font-family: var(--sb-sans);
      }
      .tech-spotlight-stage {
        font-size: 10px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 3px;
        white-space: nowrap;
        font-family: var(--sb-sans);
      }
      .tech-spotlight-tagline {
        font-size: 12px;
        color: var(--sb-muted);
        line-height: 1.5;
        margin: 0;
        font-family: var(--sb-sans);
      }
      .tech-spotlight-employees {
        font-size: 10px;
        color: var(--sb-light);
        font-family: 'Space Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding-top: 4px;
        border-top: 1px solid var(--sb-border-light);
        margin-top: 4px;
      }

      /* Footer note */
      .tech-footer-note {
        font-size: 11px;
        color: var(--sb-light);
        line-height: 1.6;
        padding-top: 16px;
        border-top: 1px solid var(--sb-border-light);
      }

      /* ── Plan My Day ─────────────────────────────────────────────────────── */

      .plan-view {
        max-width: 680px;
      }

      /* Form sections */
      .plan-section {
        margin-bottom: 24px;
      }
      .plan-section-label {
        font-family: var(--sb-sans);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        margin-bottom: 10px;
      }
      .plan-options {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      /* Individual option pill */
      .plan-option {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        padding: 10px 14px;
        border: 1.5px solid var(--sb-border);
        border-radius: 6px;
        background: var(--sb-card);
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s, color 0.15s;
        min-width: 72px;
        text-align: center;
      }
      .plan-option:hover {
        border-color: var(--sb-ink);
      }
      .plan-option--active {
        border-color: var(--sb-ink);
        background: var(--sb-ink);
        color: white;
      }
      .plan-option-emoji {
        font-size: 18px;
        line-height: 1;
      }
      .plan-option-label {
        font-size: 12px;
        font-weight: 600;
        font-family: var(--sb-sans);
        color: inherit;
        white-space: nowrap;
      }
      .plan-option-sub {
        font-size: 10px;
        color: var(--sb-light);
        font-family: var(--sb-sans);
        white-space: nowrap;
      }
      .plan-option--active .plan-option-sub {
        color: rgba(255,255,255,0.65);
      }

      /* CTA button */
      .plan-cta {
        display: inline-block;
        padding: 13px 28px;
        background: var(--sb-ink);
        color: white;
        border: none;
        border-radius: 4px;
        font-family: var(--sb-sans);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.02em;
        cursor: pointer;
        margin-top: 8px;
        transition: opacity 0.15s;
      }
      .plan-cta:hover { opacity: 0.88; }
      .plan-cta:disabled { opacity: 0.55; cursor: default; }
      .plan-cta--secondary {
        background: transparent;
        color: var(--sb-ink);
        border: 1.5px solid var(--sb-border);
        padding: 10px 20px;
        font-size: 13px;
      }
      .plan-cta--secondary:hover {
        border-color: var(--sb-ink);
        opacity: 1;
      }

      /* Result headline */
      .plan-headline {
        font-family: var(--sb-serif);
        font-size: 26px;
        font-weight: 700;
        color: var(--sb-ink);
        margin: 0 0 14px 0;
        line-height: 1.25;
      }

      /* Weather note */
      .plan-weather {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        background: var(--sb-primary-light);
        border: 1px solid var(--sb-border-light);
        border-radius: var(--sb-radius);
        font-size: 13px;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }

      /* Stop card */
      .plan-stop-card {
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
        border-radius: var(--sb-radius);
        padding: 16px 18px;
        transition: box-shadow 0.15s;
      }
      .plan-stop-card:hover {
        box-shadow: var(--sb-shadow-hover);
      }

      /* Plan mobile overrides */
      @media (max-width: 640px) {
        .plan-option { min-width: 60px; padding: 8px 10px; }
        .plan-option-emoji { font-size: 16px; }
        .plan-option-label { font-size: 11px; }
        .plan-headline { font-size: 20px; }
      }

      /* ── Development section ── */
      .dev-view {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      /* Header */
      .dev-header {
        border-bottom: 3px double var(--sb-border);
        padding-bottom: 20px;
      }
      .dev-header-eyebrow {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }
      .dev-header-title {
        font-family: var(--sb-serif);
        font-size: 36px;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: var(--sb-ink);
        margin: 0 0 8px 0;
        line-height: 1.1;
      }
      .dev-header-subtitle {
        font-size: 15px;
        color: var(--sb-muted);
        margin: 0 0 10px 0;
        line-height: 1.5;
        max-width: 600px;
      }
      .dev-header-note {
        font-size: 11px;
        color: var(--sb-light);
        letter-spacing: 0.03em;
      }

      /* Pulse strip */
      .dev-pulse {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
      }
      .dev-pulse-item {
        background: var(--sb-card);
        padding: 16px 20px;
      }
      .dev-pulse-value {
        font-family: var(--sb-serif);
        font-size: 26px;
        font-weight: 800;
        color: var(--sb-ink);
        line-height: 1.1;
        margin-bottom: 3px;
      }
      .dev-pulse-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }
      .dev-pulse-note {
        font-size: 12px;
        color: var(--sb-light);
        line-height: 1.4;
      }

      /* Filters */
      .dev-filters-wrap {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .dev-filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .dev-filter-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        min-width: 44px;
        flex-shrink: 0;
      }
      .dev-filter-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .dev-filter-pill {
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 500;
        border: 1px solid var(--sb-border);
        background: var(--sb-card);
        color: var(--sb-muted);
        cursor: pointer;
        border-radius: var(--sb-radius);
        transition: all 0.15s ease;
        font-family: var(--sb-sans);
        white-space: nowrap;
      }
      .dev-filter-pill:hover {
        border-color: var(--sb-ink);
        color: var(--sb-ink);
      }
      .dev-filter-pill--active {
        background: var(--sb-ink);
        color: #fff;
        border-color: var(--sb-ink);
      }

      /* Results count */
      .dev-results-count {
        font-size: 12px;
        color: var(--sb-light);
        letter-spacing: 0.03em;
        border-top: 1px solid var(--sb-border-light);
        padding-top: 12px;
      }

      /* Projects list */
      .dev-section-grid {
        /* defined inline per section */
      }
      .dev-project-card:hover {
        box-shadow: var(--sb-shadow-hover);
      }

      /* Card meta row */
      .dev-card-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 8px;
      }
      .dev-status-badge {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 3px 8px;
        border-radius: 2px;
      }
      .dev-category-tag {
        font-size: 11px;
        font-weight: 600;
        color: var(--sb-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 3px 8px;
        border: 1px solid var(--sb-border-light);
        background: var(--sb-bg);
        border-radius: 2px;
      }
      .dev-featured-badge {
        font-size: 11px;
        font-weight: 700;
        color: var(--sb-accent);
        letter-spacing: 0.04em;
      }

      /* Card title */
      .dev-card-title {
        font-family: var(--sb-serif);
        font-size: 20px;
        font-weight: 800;
        color: var(--sb-ink);
        margin: 0 0 4px 0;
        line-height: 1.2;
        letter-spacing: -0.01em;
      }
      .dev-card-location {
        font-size: 12px;
        color: var(--sb-muted);
        margin-bottom: 10px;
        letter-spacing: 0.02em;
      }
      .dev-card-description {
        font-size: 14px;
        color: var(--sb-muted);
        line-height: 1.6;
        margin: 0 0 14px 0;
        max-width: 680px;
      }

      /* Detail pills */
      .dev-card-details {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
      }
      .dev-detail {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .dev-detail-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--sb-light);
      }
      .dev-detail-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--sb-ink);
      }

      /* Empty state */
      .dev-empty {
        text-align: center;
        padding: 48px 24px;
        color: var(--sb-muted);
        font-size: 14px;
        background: var(--sb-card);
        border: 1px solid var(--sb-border-light);
      }
      .dev-empty-icon {
        font-size: 28px;
        margin-bottom: 10px;
        opacity: 0.5;
      }

      /* Footer note */
      .dev-footer-note {
        font-size: 11px;
        color: var(--sb-light);
        line-height: 1.6;
        padding: 16px 0 0;
        border-top: 1px solid var(--sb-border-light);
      }

      /* Development mobile */
      @media (max-width: 640px) {
        .dev-header-title { font-size: 28px; }
        .dev-pulse { grid-template-columns: repeat(2, 1fr); }
        .dev-card { padding: 16px; }
        .dev-card-title { font-size: 17px; }
        .dev-card-description { font-size: 13px; }
        .dev-card-details { gap: 12px; }
        .dev-filter-label { min-width: 36px; }
      }

      /* ── Transit & Infrastructure ── */

      .transit-view {
        padding: 0;
      }

      /* Header */
      .transit-header {
        margin-bottom: 24px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--sb-border-light);
      }
      .transit-header-eyebrow {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--sb-muted);
        margin-bottom: 8px;
      }
      .transit-header-title {
        font-family: var(--sb-serif);
        font-size: 36px;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: var(--sb-ink);
        margin: 0 0 8px 0;
        line-height: 1.1;
      }
      .transit-header-subtitle {
        font-size: 15px;
        color: var(--sb-muted);
        margin: 0 0 10px 0;
        line-height: 1.5;
        max-width: 600px;
      }
      .transit-header-note {
        font-size: 11px;
        color: var(--sb-light);
        letter-spacing: 0.03em;
      }

      /* Pulse strip */
      .transit-pulse {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
        margin-bottom: 24px;
      }
      .transit-pulse-item {
        background: var(--sb-card);
        padding: 16px 20px;
      }
      .transit-pulse-value {
        font-family: var(--sb-serif);
        font-size: 22px;
        font-weight: 800;
        color: var(--sb-ink);
        line-height: 1.1;
        margin-bottom: 3px;
      }
      .transit-pulse-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        margin-bottom: 4px;
      }
      .transit-pulse-note {
        font-size: 12px;
        color: var(--sb-light);
        line-height: 1.4;
      }

      /* Banner */
      .transit-banner {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: var(--sb-radius);
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 24px;
      }
      .transit-banner--warning {
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FDE68A;
      }
      .transit-banner-icon {
        font-size: 16px;
        flex-shrink: 0;
      }

      /* Section header */
      .transit-section-header {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 14px;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--sb-ink);
      }
      .transit-section-title {
        font-family: var(--sb-serif);
        font-size: 18px;
        font-weight: 800;
        color: var(--sb-ink);
        letter-spacing: -0.01em;
      }
      .transit-section-count {
        font-size: 12px;
        color: var(--sb-muted);
        font-weight: 500;
      }

      /* Agency grid */
      .transit-agencies-grid {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid var(--sb-border-light);
      }

      /* Agency card */
      .transit-agency-card {
        background: var(--sb-card);
        padding: 20px 24px;
        border-bottom: 1px solid var(--sb-border-light);
      }
      .transit-agency-card:last-child {
        border-bottom: none;
      }
      .transit-agency-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 8px;
        flex-wrap: wrap;
      }
      .transit-agency-title-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        flex: 1;
        min-width: 0;
      }
      .transit-agency-emoji {
        font-size: 24px;
        line-height: 1.2;
        flex-shrink: 0;
      }
      .transit-agency-name {
        font-family: var(--sb-serif);
        font-size: 18px;
        font-weight: 700;
        color: var(--sb-ink);
        margin: 0 0 3px 0;
        line-height: 1.2;
      }
      .transit-agency-description {
        font-size: 13px;
        color: var(--sb-muted);
        margin: 0;
        line-height: 1.4;
      }

      /* Status badge */
      .transit-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 2px;
        letter-spacing: 0.03em;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .transit-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .transit-status-note {
        font-size: 13px;
        color: var(--sb-muted);
        margin-bottom: 10px;
        font-style: italic;
      }

      /* Key routes */
      .transit-routes {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 12px;
      }
      .transit-route-pill {
        font-size: 11px;
        background: var(--sb-primary-light);
        color: var(--sb-muted);
        padding: 3px 8px;
        border-radius: 2px;
        border: 1px solid var(--sb-border-light);
        font-weight: 500;
      }

      /* Alerts */
      .transit-alerts {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 12px;
      }
      .transit-alert {
        background: var(--sb-primary-light);
        border-left: 3px solid var(--sb-border);
        padding: 10px 12px;
        border-radius: 0 var(--sb-radius) var(--sb-radius) 0;
      }
      .transit-alert-summary {
        font-size: 13px;
        font-weight: 600;
        color: var(--sb-ink);
        margin-bottom: 4px;
        line-height: 1.3;
      }
      .transit-alert-detail {
        font-size: 12px;
        color: var(--sb-muted);
        line-height: 1.5;
        margin-bottom: 6px;
      }
      .transit-alert-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .transit-alert-routes {
        font-size: 11px;
        font-weight: 700;
        color: var(--sb-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .transit-alert-date {
        font-size: 11px;
        color: var(--sb-light);
      }

      /* Agency links */
      .transit-agency-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-top: 4px;
      }
      .transit-link {
        font-size: 12px;
        font-weight: 600;
        color: var(--sb-muted);
        text-decoration: none;
        padding-bottom: 1px;
        border-bottom: 1px solid var(--sb-border-light);
      }
      .transit-link--primary {
        color: var(--sb-ink);
        border-color: var(--sb-ink);
      }
      .transit-link:hover {
        color: var(--sb-ink);
        border-color: var(--sb-ink);
      }

      /* Road projects grid */
      .transit-roads-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
      }
      .transit-road-card {
        background: var(--sb-card);
        padding: 18px 20px;
      }
      .transit-road-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
        flex-wrap: wrap;
      }
      .transit-road-highway {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--sb-muted);
        margin-bottom: 2px;
      }
      .transit-road-type {
        font-size: 10px;
        color: var(--sb-light);
        letter-spacing: 0.04em;
      }
      .transit-road-title {
        font-family: var(--sb-serif);
        font-size: 15px;
        font-weight: 700;
        color: var(--sb-ink);
        margin: 0 0 4px 0;
        line-height: 1.3;
      }
      .transit-road-cities {
        font-size: 11px;
        color: var(--sb-muted);
        margin-bottom: 8px;
      }
      .transit-road-description {
        font-size: 13px;
        color: var(--sb-muted);
        margin: 0 0 8px 0;
        line-height: 1.5;
      }
      .transit-road-schedule {
        font-size: 11px;
        color: var(--sb-light);
        font-style: italic;
      }
      .transit-impact-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 3px 7px;
        border-radius: 2px;
        letter-spacing: 0.03em;
        white-space: nowrap;
        flex-shrink: 0;
      }

      /* Milestones */
      .transit-milestones {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid var(--sb-border-light);
      }
      .transit-milestone-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 20px;
        background: var(--sb-card);
        border-bottom: 1px solid var(--sb-border-light);
      }
      .transit-milestone-row:last-child {
        border-bottom: none;
      }
      .transit-milestone-content {
        flex: 1;
        min-width: 0;
      }
      .transit-milestone-project {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--sb-muted);
        margin-bottom: 3px;
      }
      .transit-milestone-milestone {
        font-size: 14px;
        font-weight: 600;
        color: var(--sb-ink);
        line-height: 1.3;
        margin-bottom: 4px;
      }
      .transit-milestone-note {
        font-size: 12px;
        color: var(--sb-light);
        line-height: 1.4;
      }
      .transit-milestone-right {
        text-align: right;
        flex-shrink: 0;
      }
      .transit-milestone-date {
        font-size: 13px;
        font-weight: 700;
        color: var(--sb-ink);
        margin-bottom: 3px;
        font-family: var(--sb-serif);
      }
      .transit-milestone-status {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
      }

      /* Quick links */
      .transit-quicklinks {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--sb-border-light);
        border: 1px solid var(--sb-border-light);
        margin-bottom: 32px;
      }
      .transit-quicklink {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding: 16px 18px;
        background: var(--sb-card);
        text-decoration: none;
        transition: background 0.12s ease;
        position: relative;
      }
      .transit-quicklink:hover {
        background: var(--sb-primary-light);
      }
      .transit-quicklink-label {
        font-size: 13px;
        font-weight: 700;
        color: var(--sb-ink);
        line-height: 1.2;
      }
      .transit-quicklink-desc {
        font-size: 12px;
        color: var(--sb-muted);
        line-height: 1.3;
      }
      .transit-quicklink-arrow {
        font-size: 13px;
        color: var(--sb-muted);
        margin-top: 4px;
      }

      /* Footer note */
      .transit-footer-note {
        font-size: 11px;
        color: var(--sb-light);
        line-height: 1.6;
        padding: 16px 0 0;
        border-top: 1px solid var(--sb-border-light);
      }

      /* Transit mobile */
      @media (max-width: 640px) {
        .transit-header-title { font-size: 28px; }
        .transit-pulse { grid-template-columns: repeat(2, 1fr); }
        .transit-pulse-item:last-child { grid-column: span 2; }
        .transit-agency-card { padding: 16px; }
        .transit-agency-header { flex-direction: column; align-items: flex-start; }
        .transit-roads-grid { grid-template-columns: 1fr; }
        .transit-road-card { padding: 16px; }
        .transit-quicklinks { grid-template-columns: 1fr; }
        .transit-milestone-row { padding: 14px 16px; }
        .transit-milestone-right { display: none; }
      }

      /* ── Photo strip marquee ── */
      @keyframes photo-scroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .photo-strip-track {
        display: flex;
        gap: 3px;
        width: max-content;
        animation: photo-scroll 90s linear infinite;
      }
      .photo-strip-track:hover { animation-play-state: paused; }
      .apod-strip-track {
        display: flex;
        gap: 3px;
        width: max-content;
        animation: photo-scroll 120s linear infinite;
      }
      .apod-strip-track:hover { animation-play-state: paused; }
      .ps-caption {
        position: absolute; bottom: 0; left: 0; right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        padding: 20px 8px 6px;
        opacity: 0;
        transition: opacity 0.15s;
      }
      .photo-strip-track a:hover .ps-caption { opacity: 1; }

      /* ── Footer ── */
      .sb-footer {
        max-width: var(--sb-max-width);
        margin: 0 auto;
        padding: 22px 24px 18px;
        text-align: center;
        font-size: 11px;
        color: var(--sb-light);
        border-top: 3px double var(--sb-border);
        letter-spacing: 0.02em;
      }
      @media (max-width: 560px) {
        .sb-footer { padding: 18px 16px 14px; }
      }
      .sb-footer a {
        color: var(--sb-muted);
        text-decoration: none;
      }
      .sb-footer a:hover { text-decoration: underline; }

      /* ── Responsive ── */
      /* ── Signal Briefing ── */
      .sb-briefing-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border: 1px solid var(--sb-border-light);
      }
      .sb-briefing-card {
        background: var(--sb-card);
        border: none;
        border-right: 1px solid var(--sb-border-light);
        padding: 18px 18px 16px;
        text-align: left;
        font-family: inherit;
        cursor: pointer;
        transition: background 0.12s;
        display: flex;
        flex-direction: column;
        gap: 0;

---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import ReaderWidget from "../components/south-bay/ReaderWidget";

interface Props {
  title: string;
  description: string;
  /** Google Fonts CSS URL */
  fontsUrl?: string;
  /** meta theme-color */
  themeColor?: string;
}

const {
  title,
  description,
  fontsUrl = "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap",
  themeColor = "#f8f4ef",
} = Astro.props;

const siteUrl = "https://southbaytoday.org";
const ogImage = `${siteUrl}/images/og-image.png`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={themeColor} />
    <meta name="google-site-verification" content="4J5MfYgHPV6QgK0aDsuemTx6Erwm0hL1AkMozLvcAzw" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@stephenstanwood" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={siteUrl} />
    <a rel="me" href="https://mastodon.social/@southbaytoday" style="display:none">Mastodon</a>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsUrl} rel="stylesheet" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-nav">Skip to content</a>
    <main id="main-content">
      <slot />
    </main>
    <ReaderWidget client:idle />
    <script is:inline>
      if (location.search.includes('notrack')) localStorage.setItem('notrack', '1');
      if (localStorage.getItem('notrack')) window.webAnalyticsBeforeSend = () => null;
    </script>
    <Analytics />
  </body>
</html>

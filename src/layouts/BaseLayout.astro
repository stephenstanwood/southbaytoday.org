---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import ReaderWidget from "../components/south-bay/ReaderWidget";

interface Props {
  title: string;
  description: string;
  /** Google Fonts CSS URL */
  fontsUrl?: string;
  /** meta theme-color */
  themeColor?: string;
  /** keep page out of search indexes */
  noindex?: boolean;
  /** absolute URL for og:image / twitter:image (defaults to the site card) */
  ogImage?: string;
}

const {
  title,
  description,
  fontsUrl = "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap",
  themeColor = "#f8f4ef",
  noindex = false,
  ogImage: ogImageProp,
} = Astro.props;

const siteUrl = "https://southbaytoday.org";
const pagePath = Astro.url.pathname === "/" ? "" : Astro.url.pathname;
const pageUrl = `${siteUrl}${pagePath}`;
const ogImage = ogImageProp || `${siteUrl}/images/og-image.png`;

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: "The South Bay Today",
      alternateName: "South Bay Today",
      url: siteUrl,
      logo: `${siteUrl}/icon-512.png`,
      email: "hello@southbaytoday.org",
      sameAs: ["https://mastodon.social/@southbaytoday"],
      parentOrganization: {
        "@type": "Organization",
        name: "Stoa Works LLC",
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "The South Bay Today",
      alternateName: "South Bay Today",
      url: siteUrl,
      publisher: { "@id": `${siteUrl}/#organization` },
      inLanguage: "en-US",
      description:
        "Day plans, events, restaurants, and local government coverage across the South Bay: San Jose, Campbell, Los Gatos, Mountain View, Palo Alto, and more.",
    },
  ],
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={themeColor} />
    <meta name="google-site-verification" content="4J5MfYgHPV6QgK0aDsuemTx6Erwm0hL1AkMozLvcAzw" />
    <meta name="p:domain_verify" content="20abfa2be74d95110b898926172f52eb" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="The South Bay Today" />
    <meta name="apple-mobile-web-app-title" content="South Bay Today" />
    <meta name="msapplication-TileColor" content="#8738F5" />
    <meta name="msapplication-TileImage" content="/icon-192.png" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="The South Bay Today" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@southbaysignal" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={pageUrl} />
    <link rel="me" href="https://mastodon.social/@southbaytoday" />
    <script type="application/ld+json" set:html={websiteSchema} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="The South Bay Today — Events" href="/rss.xml" />
    <link rel="alternate" type="text/plain" title="The South Bay Today — guide for AI agents" href="/llms.txt" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsUrl} rel="stylesheet" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-nav">Skip to content</a>
    <main id="main-content">
      <slot />
    </main>
    <ReaderWidget client:idle />
    <script is:inline>
      if (location.search.includes('notrack')) localStorage.setItem('notrack', '1');
      if (localStorage.getItem('notrack')) window.webAnalyticsBeforeSend = () => null;
    </script>
    <Analytics />
  </body>
</html>

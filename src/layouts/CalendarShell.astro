---
// Shared chrome for the static crawlable pages (/events/<date>, /event/<slug>).
// Pure HTML masthead + footer around a slot; styles are global but namespaced
// under .cal-page. No React, no hydration — these pages exist for crawlers,
// no-JS readers, and fast cold loads.
import BaseLayout from "./BaseLayout.astro";
import Masthead, { type MastheadProps } from "../components/south-bay/Masthead";

interface Props {
  title: string;
  description: string;
  /** absolute URL for og:image (e.g. an event's photo) */
  ogImage?: string;
  /** highlight a nav tab when the page corresponds to one; omit/null for sub-routes */
  activeTab?: MastheadProps["activeTab"];
}

const { title, description, ogImage, activeTab = null } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  themeColor="#F7F8FA"
  fontsUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>

  <div class="cal-page">
    <Masthead activeTab={activeTab} />

    <main class="cal-main">
      <slot />
    </main>

    <footer class="cal-footer">
      a project of <a href="https://stanwood.dev" rel="noopener noreferrer">stanwood.dev</a>
      <span aria-hidden="true"> · </span>
      <a href="/about">about</a>
      <span aria-hidden="true"> · </span>
      <a href="/rss.xml">RSS</a>
      <span aria-hidden="true"> · </span>
      <a href="/privacy">privacy</a>
      <span aria-hidden="true"> · </span>
      <span>© Stoa Works LLC</span>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  /* Masthead is a shared React component (also used by SignalShell) that
     reads these --sb-* tokens; define them here so it renders on-brand
     instead of falling back to unset custom properties. Values mirror
     SignalShell.astro's :root so cal-pages read as the same site. */
  :root {
    --sb-bg: #FFF8F2;
    --sb-ink: #13072F;
    --sb-muted: #5f5870;
    --sb-light: #6b6178;
    --sb-accent: #8738F5;
    --sb-primary-light: #F4ECFF;
    --sb-max-width: 960px;
    --sb-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
    --sb-sans: 'Inter', system-ui, -apple-system, sans-serif;
  }
  .cal-page {
    --ink: #13072F;
    --muted: #555;
    --light: #888;
    --border: #c8c4bc;
    --border-light: #e5e2db;
    background: linear-gradient(180deg, #fff8f2 0%, #fff7ff 44%, #f3fbff 100%);
    color: var(--ink);
    font-family: "Inter", system-ui, sans-serif;
    min-height: 100vh;
  }
  .cal-main {
    max-width: 760px;
    margin: 0 auto;
    padding: 26px 20px 48px;
  }
  .cal-daynav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .cal-daynav a {
    font-family: "Space Mono", monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
  }
  .cal-daynav a:hover {
    text-decoration: underline;
  }
  .cal-kicker {
    font-family: "Space Mono", monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .cal-page h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 38px;
    font-weight: 900;
    line-height: 1.05;
    margin: 0 0 8px;
  }
  .cal-sub {
    color: var(--muted);
    font-size: 14px;
    margin: 0 0 26px;
    padding-bottom: 18px;
    border-bottom: 3px double var(--border);
  }
  .cal-sub a {
    color: inherit;
    font-weight: 600;
  }
  .cal-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .cal-event {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr);
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .cal-time {
    font-family: "Space Mono", monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
    white-space: nowrap;
    padding-top: 3px;
  }
  .cal-body h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 18px;
    font-weight: 800;
    line-height: 1.25;
    margin: 0 0 4px;
  }
  .cal-body h2 a {
    color: var(--ink);
    text-decoration: none;
  }
  .cal-body h2 a:hover {
    text-decoration: underline;
  }
  .cal-meta {
    margin: 0;
    font-size: 12.5px;
    color: var(--muted);
  }
  .cal-chip {
    display: inline-block;
    margin-left: 8px;
    padding: 1px 8px;
    border: 1px solid #bbf7d0;
    background: #f0fdf4;
    color: #15803d;
    border-radius: 999px;
    font-family: "Space Mono", monospace;
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    vertical-align: 1px;
  }
  .cal-chip--kids {
    border-color: #fde68a;
    background: #fffbeb;
    color: #b45309;
  }
  .cal-copy {
    margin: 6px 0 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 60ch;
  }
  .cal-footer {
    text-align: center;
    padding: 22px 16px 30px;
    border-top: 1px solid var(--border);
    color: var(--light);
    font-size: 12px;
  }
  .cal-footer a {
    color: inherit;
  }
  @media (max-width: 540px) {
    .cal-page h1 {
      font-size: 29px;
    }
    .cal-event {
      grid-template-columns: 1fr;
      gap: 3px;
    }
    .cal-time {
      padding-top: 0;
    }
  }
</style>

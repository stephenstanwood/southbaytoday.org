---
/**
 * Newsletter subscription tracker — private admin view.
 *
 * Auth: ?key=<ADMIN_KEY> query param. Set ADMIN_KEY in Vercel env.
 * No session — refresh with the key in the URL each time. This is
 * intentionally simple; the page is read-only and not linked from anywhere.
 */
import { readTracker } from "../../lib/lookout/tracker.ts";
import type { NewsletterTarget, SubscribeStatus } from "../../lib/lookout/tracker.ts";

export const prerender = false;

const providedKey = Astro.url.searchParams.get("key") ?? "";
const expectedKey = process.env.ADMIN_KEY ?? import.meta.env.ADMIN_KEY ?? "";

let authed = false;
let doc: Awaited<ReturnType<typeof readTracker>> | null = null;
let loadError: string | null = null;

if (expectedKey && providedKey === expectedKey) {
  authed = true;
  try {
    doc = await readTracker();
  } catch (err) {
    loadError = (err as Error).message;
  }
}

function statusLabel(s: SubscribeStatus): string {
  switch (s) {
    case "not-attempted": return "not attempted";
    case "signup-posted": return "signed up — awaiting email";
    case "confirmed": return "confirmed";
    case "receiving": return "receiving ✅";
    case "failed": return "failed";
    case "needs-manual": return "needs manual click";
    case "blocked": return "blocked";
  }
}

function statusColor(s: SubscribeStatus): string {
  switch (s) {
    case "receiving": return "#16a34a";
    case "confirmed": return "#2563eb";
    case "signup-posted": return "#6366f1";
    case "not-attempted": return "#6b7280";
    case "needs-manual": return "#d97706";
    case "failed": return "#dc2626";
    case "blocked": return "#7c2d12";
  }
}

function relativeTime(iso: string | undefined): string {
  if (!iso) return "—";
  const then = new Date(iso).getTime();
  const diff = Date.now() - then;
  if (diff < 60_000) return "just now";
  if (diff < 3600_000) return `${Math.floor(diff / 60_000)}m ago`;
  if (diff < 86400_000) return `${Math.floor(diff / 3600_000)}h ago`;
  return `${Math.floor(diff / 86400_000)}d ago`;
}

const targets = doc?.targets ?? [];
const grouped: Record<string, NewsletterTarget[]> = {};
for (const t of targets) {
  (grouped[t.category] ??= []).push(t);
}

const summary = {
  total: targets.length,
  receiving: targets.filter((t) => t.status === "receiving").length,
  signupPosted: targets.filter((t) => t.status === "signup-posted").length,
  confirmed: targets.filter((t) => t.status === "confirmed").length,
  notAttempted: targets.filter((t) => t.status === "not-attempted").length,
  needsManual: targets.filter((t) => t.status === "needs-manual").length,
  failed: targets.filter((t) => t.status === "failed").length,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Newsletter tracker — SBT admin</title>
    <style>
      :root {
        --bg: #fafaf9;
        --fg: #1c1917;
        --muted: #78716c;
        --card: #ffffff;
        --border: #e7e5e4;
      }
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 24px 16px;
        line-height: 1.5;
      }
      .container { max-width: 1100px; margin: 0 auto; }
      h1 { font-size: 24px; margin: 0 0 4px; }
      .sub { color: var(--muted); font-size: 14px; margin-bottom: 24px; }
      .summary {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 8px;
        margin-bottom: 24px;
      }
      .stat {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px 16px;
      }
      .stat .num { font-size: 22px; font-weight: 600; }
      .stat .lbl { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
      h2 { font-size: 16px; margin: 24px 0 8px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
      table { width: 100%; border-collapse: collapse; background: var(--card); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
      th, td { text-align: left; padding: 8px 12px; font-size: 14px; border-bottom: 1px solid var(--border); vertical-align: top; }
      th { background: #f5f5f4; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
      tr:last-child td { border-bottom: none; }
      .name { font-weight: 500; }
      .provider { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--muted); }
      .status-pill { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 500; color: white; }
      .meta { font-size: 12px; color: var(--muted); }
      a { color: #2563eb; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .unauth { max-width: 400px; margin: 80px auto; text-align: center; }
      .unauth input { padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; width: 100%; font-size: 14px; }
      .unauth button { margin-top: 8px; padding: 8px 16px; background: #2563eb; color: white; border: 0; border-radius: 6px; font-size: 14px; cursor: pointer; }
    </style>
  </head>
  <body>
    <div class="container">
      {!authed ? (
        <div class="unauth">
          <h1>Newsletter tracker</h1>
          <p class="sub">private admin view</p>
          <form method="GET">
            <input name="key" type="password" placeholder="admin key" autofocus />
            <button type="submit">View</button>
          </form>
        </div>
      ) : loadError ? (
        <div>
          <h1>Newsletter tracker</h1>
          <p class="sub">failed to load tracker: {loadError}</p>
        </div>
      ) : (
        <>
          <h1>Newsletter tracker</h1>
          <p class="sub">Last updated {doc && relativeTime(doc.updatedAt)} • {targets.length} targets</p>

          <div class="summary">
            <div class="stat"><div class="num">{summary.receiving}</div><div class="lbl">receiving</div></div>
            <div class="stat"><div class="num">{summary.signupPosted}</div><div class="lbl">awaiting first email</div></div>
            <div class="stat"><div class="num">{summary.confirmed}</div><div class="lbl">confirmed</div></div>
            <div class="stat"><div class="num">{summary.notAttempted}</div><div class="lbl">not attempted</div></div>
            <div class="stat"><div class="num">{summary.needsManual}</div><div class="lbl">needs manual</div></div>
            <div class="stat"><div class="num">{summary.failed}</div><div class="lbl">failed</div></div>
          </div>

          {Object.entries(grouped).sort().map(([category, items]) => (
            <>
              <h2>{category}</h2>
              <table>
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Last received</th>
                    <th>Count</th>
                    <th>Attempted</th>
                  </tr>
                </thead>
                <tbody>
                  {items.sort((a, b) => a.name.localeCompare(b.name)).map((t) => (
                    <tr>
                      <td>
                        <div class="name"><a href={t.signupUrl} target="_blank">{t.name}</a></div>
                        <div class="provider">{t.provider}</div>
                        {t.notes && <div class="meta">{t.notes}</div>}
                      </td>
                      <td class="meta">{t.city ?? "—"}</td>
                      <td><span class="status-pill" style={`background: ${statusColor(t.status)}`}>{statusLabel(t.status)}</span></td>
                      <td class="meta">{relativeTime(t.lastReceivedAt)}</td>
                      <td class="meta">{t.receivedCount ?? 0}</td>
                      <td class="meta">{relativeTime(t.attemptedAt)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </>
          ))}
        </>
      )}
    </div>
  </body>
</html>

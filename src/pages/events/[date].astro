---
// Static per-date event listings — the crawlable layer for the events data.
// The interactive Events tab is a client:only React app, so these pages are
// what search engines (and no-JS readers) actually see. Pure Astro, no
// hydration; regenerated on every nightly data build.
import CalendarShell from "../../layouts/CalendarShell.astro";
import upcomingData from "../../data/south-bay/upcoming-events.json";
import { CITIES } from "../../lib/south-bay/cities";
import { parseClockTime } from "../../lib/south-bay/calendarLink";
import { buildEventSlugs } from "../../lib/south-bay/eventSlug";
import { eventListJsonLd, type SchemaEventRecord } from "../../lib/south-bay/eventSchema";

// This file compiles to a component named `Date` (from the [date] param),
// shadowing the global Date constructor in the language server's view of the
// module. Alias the real constructor so date math typechecks.
const DateCtor = globalThis.Date;

interface RawEvent {
  id?: string | null;
  title?: string | null;
  date?: string | null;
  time?: string | null;
  endTime?: string | null;
  venue?: string | null;
  address?: string | null;
  city?: string | null;
  url?: string | null;
  image?: string | null;
  photoRef?: string | null;
  blurb?: string | null;
  description?: string | null;
  cost?: string | null;
  kidFriendly?: boolean | null;
  category?: string | null;
}

export function getStaticPaths() {
  const WINDOW_DAYS = 60; // defined inside: getStaticPaths runs in isolated scope
  const DateCtor = globalThis.Date; // ditto — see module-level alias note
  const cityNames = new Map<string, string>(CITIES.map((c) => [c.id, c.name]));
  const all = (upcomingData as { events?: RawEvent[] }).events ?? [];

  // Reverse lookup id → detail slug so listing links match /event/[slug].
  const slugById = new Map<string, string>();
  for (const [slug, e] of buildEventSlugs(all)) {
    if (e.id) slugById.set(String(e.id), slug);
  }

  const todayPt = new DateCtor().toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
  const horizon = new DateCtor();
  horizon.setDate(horizon.getDate() + WINDOW_DAYS);
  const horizonPt = horizon.toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });

  const byDate = new Map<string, RawEvent[]>();
  for (const e of all) {
    const date = e?.date;
    if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date)) continue;
    if (date < todayPt || date > horizonPt) continue;
    if (!e.time) continue; // exhibits / no-time records stay off date listings
    if (!byDate.has(date)) byDate.set(date, []);
    byDate.get(date)!.push(e);
  }

  const dates = [...byDate.keys()].sort();
  return dates.map((date, i) => {
    const events = byDate
      .get(date)!
      .slice()
      .sort((a, b) => {
        const ta = parseClockTime(a.time);
        const tb = parseClockTime(b.time);
        return (ta ? ta.h * 60 + ta.m : 1441) - (tb ? tb.h * 60 + tb.m : 1441);
      })
      .map((e) => {
        const t = parseClockTime(e.time);
        return {
          ...e,
          cityName: e.city ? cityNames.get(e.city) ?? null : null,
          detailSlug: e.id ? slugById.get(String(e.id)) ?? null : null,
          // Minutes-since-midnight start time, used client-side to dim
          // already-started events when this date happens to be "today" in
          // the visitor's Pacific-time clock (the page itself is static and
          // can't know "now" at build time).
          startMinutes: t ? t.h * 60 + t.m : null,
        };
      });
    return {
      params: { date },
      props: {
        date,
        events,
        prevDate: i > 0 ? dates[i - 1] : null,
        nextDate: i < dates.length - 1 ? dates[i + 1] : null,
      },
    };
  });
}

interface Props {
  date: string;
  events: (RawEvent & { cityName: string | null; detailSlug: string | null; startMinutes: number | null })[];
  prevDate: string | null;
  nextDate: string | null;
}

const { date, events, prevDate, nextDate } = Astro.props;

const dayLabel = new DateCtor(`${date}T12:00:00Z`).toLocaleDateString("en-US", {
  timeZone: "UTC",
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
});
const shortLabel = (d: string) =>
  new DateCtor(`${d}T12:00:00Z`).toLocaleDateString("en-US", { timeZone: "UTC", weekday: "short", month: "short", day: "numeric" });

const cityCount = new Set(events.map((e) => e.city).filter(Boolean)).size;
const title = `Events on ${dayLabel} — South Bay Today`;
const description = `${events.length} things happening across the South Bay on ${dayLabel}: ${events
  .slice(0, 3)
  .map((e) => e.title)
  .filter(Boolean)
  .join(", ")}, and more.`;

const listJsonLd = eventListJsonLd(events.map((event) => ({
  ...event,
  pageUrl: event.detailSlug ? `https://southbaytoday.org/event/${event.detailSlug}` : null,
})) as SchemaEventRecord[], {
  name: `South Bay events on ${dayLabel}`,
  url: `https://southbaytoday.org/events/${date}`,
  limit: 60,
});
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "South Bay Today", item: "https://southbaytoday.org" },
    { "@type": "ListItem", position: 2, name: "Events", item: "https://southbaytoday.org/events" },
    { "@type": "ListItem", position: 3, name: dayLabel },
  ],
});
---

<CalendarShell title={title} description={description} activeTab="events">
  <Fragment slot="head">
    {listJsonLd && <script type="application/ld+json" set:html={listJsonLd} />}
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <nav class="cal-daynav" aria-label="Browse days">
    {prevDate ? <a href={`/events/${prevDate}`}>← {shortLabel(prevDate)}</a> : <span />}
    <span class="cal-kicker">South Bay / Calendar</span>
    {nextDate ? <a href={`/events/${nextDate}`}>{shortLabel(nextDate)} →</a> : <span />}
  </nav>

  <h1>{dayLabel}</h1>
  <p class="cal-sub">
    {events.length} {events.length === 1 ? "event" : "events"} across {cityCount}{" "}
    {cityCount === 1 ? "city" : "South Bay cities"} ·{" "}
    <a href="/events">search &amp; filter on the Events tab →</a>
  </p>

  <ol class="cal-list">
    {events.map((e) => (
      <li class="cal-event" data-start-min={e.startMinutes ?? ""}>
        <div class="cal-time">{e.time}</div>
        <div class="cal-body">
          <h2>
            {e.detailSlug ? (
              <a href={`/event/${e.detailSlug}`}>{e.title}</a>
            ) : e.url ? (
              <a href={e.url} rel="noopener noreferrer">{e.title}</a>
            ) : (
              e.title
            )}
          </h2>
          <p class="cal-meta">
            {[e.venue, e.cityName].filter(Boolean).join(" · ")}
            {e.cost === "free" && <span class="cal-chip">Free</span>}
            {e.kidFriendly && <span class="cal-chip cal-chip--kids">Kids</span>}
          </p>
          {(e.blurb || e.description) && <p class="cal-copy">{e.blurb || e.description}</p>}
        </div>
      </li>
    ))}
  </ol>

  <script define:vars={{ pageDate: date }}>
    // This page is static (build-time rendered), so it can't know "now" —
    // only the visitor's browser can. When the page's date matches today in
    // Pacific time, dim any event whose start time has already passed and
    // label it, instead of silently listing it alongside events still ahead.
    const todayPt = new Date().toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
    if (pageDate === todayPt) {
      const now = new Date();
      const nowPt = new Date(now.toLocaleString("en-US", { timeZone: "America/Los_Angeles" }));
      const nowMinutes = nowPt.getHours() * 60 + nowPt.getMinutes();
      document.querySelectorAll(".cal-event[data-start-min]").forEach((el) => {
        const raw = el.getAttribute("data-start-min");
        if (!raw) return;
        const startMinutes = Number(raw);
        if (!Number.isFinite(startMinutes) || startMinutes > nowMinutes) return;
        el.classList.add("cal-event--started");
        const meta = el.querySelector(".cal-meta");
        if (meta && !meta.querySelector(".cal-chip--started")) {
          const badge = document.createElement("span");
          badge.className = "cal-chip cal-chip--started";
          badge.textContent = "Already started";
          meta.appendChild(badge);
        }
      });
    }
  </script>

  <style>
    .cal-event--started {
      opacity: 0.55;
    }
    .cal-chip--started {
      border-color: var(--border, #e2e2e2);
      background: transparent;
      color: var(--muted, #6b6b6b);
    }
  </style>
</CalendarShell>

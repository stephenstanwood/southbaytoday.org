---
// Per-event detail pages — one stable URL per upcoming event, with a single
// schema.org Event block. These are the long-tail crawl surface ("event name
// + city" queries); the page links out prominently to the source. Pure Astro.
import CalendarShell from "../../layouts/CalendarShell.astro";
import upcomingData from "../../data/south-bay/upcoming-events.json";
import archiveData from "../../data/south-bay/events-archive.json";
import { CITIES } from "../../lib/south-bay/cities";
import { buildGoogleCalendarUrl } from "../../lib/south-bay/calendarLink";
import { buildEventSlugs } from "../../lib/south-bay/eventSlug";
import { eventToSchema, type SchemaEventRecord } from "../../lib/south-bay/eventSchema";
import { normalizeAbsoluteHttpUrl } from "../../lib/south-bay/httpUrl.mjs";

interface RawEvent {
  id?: string | null;
  title?: string | null;
  date?: string | null;
  time?: string | null;
  endTime?: string | null;
  venue?: string | null;
  address?: string | null;
  city?: string | null;
  url?: string | null;
  image?: string | null;
  photoRef?: string | null;
  blurb?: string | null;
  description?: string | null;
  cost?: string | null;
  costNote?: string | null;
  kidFriendly?: boolean | null;
  category?: string | null;
  source?: string | null;
}

export function getStaticPaths() {
  const all = (upcomingData as { events?: RawEvent[] }).events ?? [];
  const archived = (archiveData as { events?: RawEvent[] }).events ?? [];
  const todayPt = new Date().toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
  const upcoming = all.filter((e) => e.date && e.date >= todayPt && e.time);
  // Passed events keep resolving for ~30 days (the archive's window) with a
  // "this event has passed" banner — no next-morning 404s. Upcoming wins when
  // a recurring event appears in both pools.
  const past = archived.filter((e) => e.date && e.date < todayPt && e.time);
  const seen = new Set(upcoming.map((e) => `${e.date}|${e.title}`));
  const pool = [...upcoming, ...past.filter((e) => !seen.has(`${e.date}|${e.title}`))];
  return [...buildEventSlugs(pool)].map(([slug, event]) => ({
    params: { slug },
    props: {
      event,
      passed: Boolean(event.date && event.date < todayPt),
      updatedAt: event.date && event.date < todayPt
        ? (archiveData as { updatedAt?: string }).updatedAt ?? null
        : (upcomingData as { generatedAt?: string }).generatedAt ?? null,
    },
  }));
}

interface Props {
  event: RawEvent;
  passed: boolean;
  updatedAt: string | null;
}

const { event, passed, updatedAt } = Astro.props;
const cityName = event.city ? CITIES.find((c) => c.id === event.city)?.name ?? null : null;
const pageUrl = `https://southbaytoday.org${Astro.url.pathname}`;

const dayLabel = new Date(`${event.date}T12:00:00Z`).toLocaleDateString("en-US", {
  timeZone: "UTC",
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
});

const timeLabel = event.endTime && event.time ? `${event.time}–${event.endTime}` : event.time ?? "";
const metaBits = [timeLabel, event.venue, cityName].filter(Boolean);

// <title> uncapped ran long on most events — drop the year (redundant with the
// visible dayLabel elsewhere on the page) and, if it's still long, drop the
// site suffix rather than truncate the event's actual title.
const dayLabelNoYear = new Date(`${event.date}T12:00:00Z`).toLocaleDateString("en-US", {
  timeZone: "UTC",
  weekday: "long",
  month: "long",
  day: "numeric",
});
const titleCore = `${event.title} — ${dayLabelNoYear}`;
const title = titleCore.length > 68 ? titleCore : `${titleCore} — South Bay Today`;

function capDescription(text: string, max = 155): string {
  const trimmed = text.trim();
  if (trimmed.length <= max) return trimmed;
  const sliced = trimmed.slice(0, max);
  const lastSpace = sliced.lastIndexOf(" ");
  const safe = (lastSpace > 0 ? sliced.slice(0, lastSpace) : sliced).trimEnd();
  return `${safe}…`;
}
const description = capDescription(
  `${event.title} on ${dayLabel}${event.venue ? ` at ${event.venue}` : ""}${
    cityName ? ` in ${cityName}` : ""
  }. ${(event.blurb || event.description || "").trim()}`.trim(),
);

const directImageUrl = normalizeAbsoluteHttpUrl(event.image);
const imageUrl = directImageUrl
  ? directImageUrl
  : event.photoRef
    ? `/api/place-photo?ref=${encodeURIComponent(event.photoRef)}&w=760&h=420`
    : null;

const mapsQuery = [event.venue, event.address, cityName ? `${cityName}, CA` : null]
  .filter(Boolean)
  .join(", ");
const mapsUrl = mapsQuery ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapsQuery)}` : null;

// Address strings pulled from source listings often repeat the venue name
// ("Frost Amphitheater, 327 Lasuen St, ..."). The "Where" line already shows
// the venue, so strip a leading venue prefix before rendering the address.
function stripVenuePrefix(address: string | null | undefined, venue: string | null | undefined): string {
  const addr = (address ?? "").trim();
  const v = (venue ?? "").trim();
  if (!addr || !v) return addr;
  const escaped = v.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  const re = new RegExp(`^${escaped}\\s*,?\\s*`, "i");
  return addr.replace(re, "").trim();
}
const displayAddress = stripVenuePrefix(event.address, event.venue);

const calendarUrl = buildGoogleCalendarUrl({
  title: event.title ?? "",
  date: event.date ?? "",
  time: event.time,
  endTime: event.endTime,
  venue: event.venue,
  address: event.address,
  city: event.city,
  description: event.description,
  blurb: event.blurb,
  url: event.url,
});

const eventSchema = eventToSchema({ ...event, cityName, pageUrl } as SchemaEventRecord);
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${pageUrl}#webpage`,
  url: pageUrl,
  name: title,
  inLanguage: "en-US",
  ...(updatedAt ? { dateModified: updatedAt } : {}),
  ...(eventSchema ? { mainEntity: { "@id": `${pageUrl}#event` } } : {}),
};
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "South Bay Today", item: "https://southbaytoday.org" },
    { "@type": "ListItem", position: 2, name: "Events", item: "https://southbaytoday.org/events" },
    { "@type": "ListItem", position: 3, name: dayLabel, item: `https://southbaytoday.org/events/${event.date}` },
    { "@type": "ListItem", position: 4, name: event.title ?? "", item: pageUrl },
  ],
};
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": eventSchema ? [webPageSchema, eventSchema, breadcrumbSchema] : [webPageSchema, breadcrumbSchema],
});

const updatedLabel = updatedAt
  ? new Date(updatedAt).toLocaleString("en-US", {
      timeZone: "America/Los_Angeles",
      month: "short",
      day: "numeric",
      year: "numeric",
      hour: "numeric",
      minute: "2-digit",
      timeZoneName: "short",
    })
  : null;

// "More at {venue}" — other upcoming events at the same venue, case-insensitive
// match, soonest first, capped at 4. Self is excluded by date+title (same key
// getStaticPaths' dedup uses above), not just object identity, so this still
// holds if props ever stop being passed by reference.
const venueTodayPt = new Date().toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
const upcomingPool = ((upcomingData as { events?: RawEvent[] }).events ?? []).filter(
  (e) => e.date && e.date >= venueTodayPt && e.time,
);
const venueSlugs = buildEventSlugs(upcomingPool);
const slugByEvent = new Map<RawEvent, string>();
for (const [slug, e] of venueSlugs) slugByEvent.set(e, slug);
const eventVenueKey = (event.venue ?? "").trim().toLowerCase();
const isSelf = (e: RawEvent) => e === event || (e.date === event.date && e.title === event.title);
const moreAtVenue = eventVenueKey
  ? upcomingPool
      .filter((e) => !isSelf(e) && (e.venue ?? "").trim().toLowerCase() === eventVenueKey)
      .map((e) => ({ event: e, slug: slugByEvent.get(e) }))
      .filter((x): x is { event: RawEvent; slug: string } => Boolean(x.slug))
      .sort((a, b) => (a.event.date! < b.event.date! ? -1 : a.event.date! > b.event.date! ? 1 : 0))
      .slice(0, 4)
  : [];

const absoluteOgImage = imageUrl
  ? imageUrl.startsWith("http")
    ? imageUrl
    : `https://southbaytoday.org${imageUrl}`
  : undefined;

// Body copy: blurb leads; description follows only when it adds something new.
const blurb = (event.blurb ?? "").trim();
const longDesc = (event.description ?? "").trim();
const showDesc = longDesc && longDesc !== blurb && !blurb.startsWith(longDesc.slice(0, 40));
---

<CalendarShell title={title} description={description} ogImage={absoluteOgImage} activeTab="events">
  <Fragment slot="head">
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </Fragment>

  <nav class="cal-daynav" aria-label="Breadcrumb">
    {passed ? <a href="/events">← Upcoming events</a> : <a href={`/events/${event.date}`}>← {dayLabel}</a>}
    <span class="cal-kicker">South Bay / Event</span>
    <span />
  </nav>

  {passed && (
    <p class="cal-passed">
      This event has passed — it happened {dayLabel}. <a href="/events">See what's coming up →</a>
    </p>
  )}

  <h1>{event.title}</h1>
  <p class="cal-sub">
    {metaBits.join(" · ")}
    {event.cost === "free" && <span class="cal-chip">Free</span>}
    {event.cost === "paid" && <span class="cal-chip cal-chip--paid">Paid</span>}
    {event.cost === "low" && <span class="cal-chip cal-chip--low">Low cost</span>}
    {event.kidFriendly && <span class="cal-chip cal-chip--kids">Kids</span>}
  </p>

  {imageUrl && (
    <img
      class="cal-detail-photo"
      src={imageUrl}
      width="760"
      height="420"
      alt={`${event.title}${event.venue ? ` at ${event.venue}` : ""}`}
      loading="lazy"
    />
  )}

  {blurb && <p class="cal-detail-copy">{blurb}</p>}
  {showDesc && <p class="cal-detail-copy cal-detail-copy--secondary">{longDesc}</p>}

  <dl class="cal-detail-facts">
    <div><dt>When</dt><dd>{dayLabel}{timeLabel ? ` · ${timeLabel}` : ""}</dd></div>
    {event.venue && (
      <div>
        <dt>Where</dt>
        <dd>
          {event.venue}
          {displayAddress ? ` — ${displayAddress}` : ""}
          {cityName ? `, ${cityName}` : ""}
          {mapsUrl && (
            <>
              {" "}· <a href={mapsUrl} rel="noopener noreferrer">map</a>
            </>
          )}
        </dd>
      </div>
    )}
    {event.source && <div><dt>Listed by</dt><dd>{event.source}</dd></div>}
    {updatedAt && updatedLabel && (
      <div><dt>Refreshed</dt><dd><time datetime={updatedAt}>{updatedLabel}</time></dd></div>
    )}
  </dl>

  <div class="cal-detail-actions">
    {event.url && (
      <a class="cal-btn cal-btn--primary" href={event.url} rel="noopener noreferrer" data-analytics-event="Event source click">
        Event details ↗
      </a>
    )}
    {!passed && calendarUrl && (
      <a class="cal-btn" href={calendarUrl} rel="noopener noreferrer" data-analytics-event="Calendar add">
        Add to Google Calendar
      </a>
    )}
    {passed ? (
      <a class="cal-btn" href="/events" data-analytics-event="Related events click">Upcoming events</a>
    ) : (
      <a class="cal-btn" href={`/events/${event.date}`} data-analytics-event="Related events click">More events this day</a>
    )}
  </div>

  {moreAtVenue.length > 0 && (
    <div class="cal-more-venue">
      <h2 class="cal-more-venue-heading">More at {event.venue}</h2>
      <div class="cal-detail-actions">
        {moreAtVenue.map(({ event: e, slug }) => (
          <a class="cal-btn" href={`/event/${slug}`} data-analytics-event="More at venue click">
            {new Date(`${e.date}T12:00:00Z`).toLocaleDateString("en-US", {
              timeZone: "UTC",
              month: "short",
              day: "numeric",
            })} · {e.title}
          </a>
        ))}
      </div>
    </div>
  )}
</CalendarShell>

<script>
  import { track } from "@vercel/analytics";

  document.querySelectorAll<HTMLElement>("[data-analytics-event]").forEach((element) => {
    element.addEventListener("click", () => {
      const eventName = element.dataset.analyticsEvent;
      if (eventName) track(eventName);
    });
  });
</script>

<style>
  .cal-chip--paid {
    border-color: #ddd6fe;
    background: #f5f3ff;
    color: #5b21b6;
  }
  .cal-chip--low {
    border-color: #fde68a;
    background: #fff7ed;
    color: #92400e;
  }
  .cal-more-venue {
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--border-light);
  }
  .cal-more-venue-heading {
    margin: 0 0 10px;
    font-family: "Space Mono", monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--light);
  }
  .cal-more-venue .cal-detail-actions {
    margin-top: 0;
  }
  .cal-passed {
    margin: 0 0 14px;
    padding: 10px 14px;
    border: 1px solid #fde68a;
    background: #fffbeb;
    color: #92400e;
    border-radius: 8px;
    font-size: 13px;
  }
  .cal-passed a {
    color: inherit;
    font-weight: 700;
  }
  .cal-detail-photo {
    width: 100%;
    aspect-ratio: 760 / 420;
    max-height: 420px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--border-light);
    margin: 0 0 18px;
  }
  .cal-detail-copy {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
    max-width: 64ch;
    margin: 0 0 12px;
  }
  .cal-detail-copy--secondary {
    font-size: 13.5px;
    color: var(--muted);
  }
  .cal-detail-facts {
    margin: 22px 0;
    border-top: 1px solid var(--border-light);
  }
  .cal-detail-facts > div {
    display: grid;
    grid-template-columns: 92px minmax(0, 1fr);
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .cal-detail-facts dt {
    font-family: "Space Mono", monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--light);
    padding-top: 3px;
  }
  .cal-detail-facts dd {
    margin: 0;
    font-size: 14px;
    color: var(--ink);
    line-height: 1.5;
  }
  .cal-detail-facts dd a {
    color: inherit;
  }
  .cal-detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }
  .cal-btn {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 6px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fff;
    color: var(--ink);
    font-family: "Space Mono", monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .cal-btn:hover {
    border-color: var(--ink);
  }
  .cal-btn--primary {
    background: var(--ink);
    border-color: var(--ink);
    color: #fff;
  }
  .cal-btn--primary:hover {
    opacity: 0.88;
  }
</style>

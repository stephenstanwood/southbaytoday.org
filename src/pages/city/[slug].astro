---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CityPage from "../../components/south-bay/city/CityPage.tsx";
import { CITIES } from "../../lib/south-bay/cities";
import upcomingData from "../../data/south-bay/upcoming-events.json";
import { eventListJsonLd, type SchemaEventRecord } from "../../lib/south-bay/eventSchema";

export function getStaticPaths() {
  return CITIES.map((city) => ({
    params: { slug: city.id },
    props: { cityId: city.id, cityName: city.name },
  }));
}

const { cityId, cityName } = Astro.props;
const title = `${cityName} — South Bay Today`;
const description = `What's happening in ${cityName} today: events, city council meetings, development updates, and local news.`;

// CityPage is client:only, so this build-time JSON-LD block (next 7 days of
// the city's events) is the only event content crawlers see on this page.
const todayPt = new Date().toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
const weekOut = new Date();
weekOut.setDate(weekOut.getDate() + 7);
const weekOutPt = weekOut.toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
const cityEvents = ((upcomingData as { events?: SchemaEventRecord[] }).events ?? [])
  .filter((e) => e.city === cityId && e.time && e.date && e.date >= todayPt && e.date <= weekOutPt)
  .map((e) => ({ ...e, cityName }));
const jsonLd = eventListJsonLd(cityEvents, {
  name: `Events in ${cityName} this week`,
  url: `https://southbaytoday.org/city/${cityId}`,
  limit: 25,
});
---

<BaseLayout
  title={title}
  description={description}
  themeColor="#F7F8FA"
  fontsUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
>
  <Fragment slot="head">
    <style is:global>
      :root {
        --sb-bg: #FAF9F6;
        --sb-card: #FFFFFF;
        --sb-ink: #1A1A1A;
        --sb-muted: #555555;
        --sb-light: #888888;
        --sb-border: #C8C4BC;
        --sb-border-light: #E5E2DB;
        --sb-primary: #1A1A1A;
        --sb-primary-light: #F0EFEC;
        --sb-accent: #C0392B;
        --sb-radius: 2px;
        --sb-shadow-hover: 0 2px 8px rgba(0, 0, 0, 0.08);
        --sb-max-width: 960px;
        --sb-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --sb-sans: 'Inter', system-ui, -apple-system, sans-serif;
      }
      body {
        font-family: var(--sb-sans);
        background: var(--sb-bg);
        color: var(--sb-ink);
        margin: 0;
        padding: 0;
      }
      /* CityPage manages its own internal width — the Masthead spans full
         width and the content has an 800px max-width matching the homepage. */
      @media (max-width: 640px) {
        .city-events-grid { grid-template-columns: 1fr !important; }
      }
    </style>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </Fragment>

  <CityPage cityId={cityId} cityName={cityName} client:only="react" />
</BaseLayout>

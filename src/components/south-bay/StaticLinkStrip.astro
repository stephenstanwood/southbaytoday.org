---
// Quiet static link blocks rendered below the app on tab/city pages. The
// point is crawl-graph: the high-authority app URLs pass internal links into
// the static layer (day listings, council pages, food openings). Pure HTML —
// renders pre-hydration and for crawlers; visually it reads as a sitemap-ish
// footer extension, deliberately understated.
import upcomingData from "../../data/south-bay/upcoming-events.json";
import digestsJson from "../../data/south-bay/digests.json";

interface Props {
  days?: boolean;
  govCities?: boolean;
  foodNew?: boolean;
}

const { days = false, govCities = false, foodNew = false } = Astro.props;

const todayPt = new Date().toLocaleDateString("en-CA", { timeZone: "America/Los_Angeles" });
const eventDates = days
  ? [...new Set(
      ((upcomingData as { events?: { date?: string; time?: string }[] }).events ?? [])
        .filter((e) => e.date && e.time && e.date >= todayPt)
        .map((e) => e.date as string),
    )]
      .sort()
      .slice(0, 14)
  : [];

const dayLabel = (d: string) =>
  new Date(`${d}T12:00:00Z`).toLocaleDateString("en-US", { timeZone: "UTC", weekday: "short", month: "short", day: "numeric" });

const govCityList = govCities
  ? Object.values(digestsJson as Record<string, { city: string; cityName: string }>)
      .map((d) => ({ id: d.city, name: d.cityName }))
      .sort((a, b) => a.name.localeCompare(b.name))
  : [];
---

{(eventDates.length > 0 || govCityList.length > 0 || foodNew) && (
  <nav class="sls" aria-label="Browse the site">
    {eventDates.length > 0 && (
      <p>
        <span class="sls-label">Events by day</span>
        {eventDates.map((d) => <a href={`/events/${d}`}>{dayLabel(d)}</a>)}
        <a href="/rss.xml">RSS</a>
        <a href="/about">About</a>
        <a href="/privacy">Privacy</a>
      </p>
    )}
    {govCityList.length > 0 && (
      <p>
        <span class="sls-label">Council summaries</span>
        {govCityList.map((c) => <a href={`/gov/${c.id}`}>{c.name}</a>)}
      </p>
    )}
    {foodNew && (
      <p>
        <span class="sls-label">Food</span>
        <a href="/food/new">New &amp; coming-soon restaurants</a>
      </p>
    )}
  </nav>
)}

<style>
  .sls {
    max-width: 960px;
    margin: 0 auto;
    padding: 6px 24px 34px;
    text-align: center;
  }
  .sls p {
    display: flex;
    flex-wrap: wrap;
    column-gap: 14px;
    row-gap: 6px;
    align-items: baseline;
    justify-content: center;
    margin: 6px 0;
    font-size: 11px;
    line-height: 1.4;
    color: #6b6178;
  }
  .sls-label {
    font-family: "Space Mono", monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .sls a {
    color: #6b6178;
    text-decoration: none;
    white-space: nowrap;
    /* 11px links need a ≥24px touch target (WCAG 2.5.8) — pad the hit area
       and let the row gaps carry the visual spacing. */
    display: inline-block;
    padding: 5px 4px;
    margin: -3px -2px;
  }
  .sls a:hover {
    color: #1a1a1a;
    text-decoration: underline;
  }
</style>
